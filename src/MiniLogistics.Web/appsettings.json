{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "PartnerApi": {
    "RateLimiting": {
      "Mode": "Memory",
      "QuoteLimitPerMinute": 60,
      "CreateShipmentLimitPerMinute": 30,
      "TrackingLimitPerMinute": 120,
      "CancelShipmentLimitPerMinute": 30
    }
  },
  "PublicTracking": {
    "RateLimiting": {
      "LimitPerMinute": 20
    }
  },
  "AllowedHosts": "*"
}
