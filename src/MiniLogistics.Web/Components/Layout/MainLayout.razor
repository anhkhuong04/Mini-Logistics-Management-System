@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="app-main">
        <header class="app-topbar">
            <button class="menu-button" type="button" aria-label="Open navigation">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" />
                </svg>
            </button>

            <AuthorizeView>
                <Authorized>
                    <div class="topbar-actions">
                        <button class="icon-button" type="button" aria-label="Notifications">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 22a2.8 2.8 0 0 0 2.7-2h-5.4A2.8 2.8 0 0 0 12 22Zm7-6V11a7 7 0 0 0-5-6.7V3a2 2 0 0 0-4 0v1.3A7 7 0 0 0 5 11v5l-2 2v1h18v-1l-2-2Zm-2 1H7v-6a5 5 0 0 1 10 0v6Z" />
                            </svg>
                        </button>

                        <div class="account-chip">
                            <span class="account-avatar" aria-hidden="true">
                                <svg viewBox="0 0 24 24">
                                    <path d="M4 10h16v10H4V10Zm2 2v6h4v-6H6Zm6 0v6h6v-6h-6ZM5 8l2-4h10l2 4H5Zm3.2-2-.5 1h8.6l-.5-1H8.2Z" />
                                </svg>
                            </span>
                            <span class="account-text">
                                <strong>@(context.User.Identity?.Name ?? "Shop")</strong>
                                <small>Shop</small>
                            </span>
                            <svg class="account-chevron" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="m7 9 5 5 5-5 1.4 1.4L12 16.8l-6.4-6.4L7 9Z" />
                            </svg>
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a class="signin-link" href="/login">Đăng nhập</a>
                </NotAuthorized>
            </AuthorizeView>
        </header>

        <article class="app-content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
