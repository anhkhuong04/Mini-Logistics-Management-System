@page "/"
@layout MiniLogistics.Web.Components.Layout.LandingLayout

<PageTitle>LAK | Nền tảng quản lý logistics</PageTitle>

<header class="site-header">
    <div class="container header-inner">
        <a class="brand" href="/" aria-label="LAK">
            <img class="brand-logo" src="/images/landing/lak-logo.svg" alt="LAK" />
        </a>

        <nav class="main-nav" aria-label="Main navigation">
            <a href="/">Trang chủ</a>
            <a href="#services">Dịch vụ</a>
            <a href="#about">Về chúng tôi</a>
            <a href="/tracking">Tra cứu</a>
        </nav>

        <div class="header-actions">
            <button class="toolbar-button toolbar-button-plain" type="button">
                <span class="toolbar-icon" aria-hidden="true">🌐</span>
                <span>VI</span>
                <span class="toolbar-caret" aria-hidden="true">⌄</span>
            </button>
            <a class="toolbar-button toolbar-button-outline" href="/download-app">Tải ứng dụng</a>
            <a class="toolbar-button toolbar-button-solid" href="/login">Đăng nhập</a>
        </div>
    </div>
</header>

<main class="landing-main">
    <section class="hero-banner">
        <img src="/images/landing/hero-banner.png" alt="LAK logistics banner" />
    </section>

    <section class="search-section">
        <div class="container search-wrap">
            <form class="tracking-form" method="get" action="/tracking">
                <input id="tracking-code" name="code" maxlength="30" required placeholder="Nhập mã đơn hàng bạn cần tra cứu" />
                <button type="submit">Theo dõi</button>
            </form>
        </div>
    </section>

    <section class="actions-section">
        <div class="container action-grid">
            <a class="action-card" href="/login">
                <strong>Bắt đầu tạo đơn</strong>
                <span>Tạo đơn lấy hàng hoặc gửi hàng</span>
            </a>
            <a class="action-card" href="/tracking">
                <strong>Tra cứu vận đơn</strong>
                <span>Kiểm tra trạng thái và lịch sử giao nhận</span>
            </a>
            <a class="action-card" href="/register-shop">
                <strong>Đăng ký shop</strong>
                <span>Tạo workspace giao nhận cho shop</span>
            </a>
        </div>
    </section>

    <section class="services-section" id="services">
        <div class="container section-narrow">
            <h2>Dịch vụ của LAK</h2>
            <div class="services-grid">
                <article class="service-item">
                    <img src="/images/landing/icon1.svg" alt="" />
                    <h3>Dịch vụ lấy hàng</h3>
                    <p>Hỗ trợ khởi tạo và xử lý yêu cầu lấy hàng rõ ràng.</p>
                </article>
                <article class="service-item">
                    <img src="/images/landing/icon2.svg" alt="" />
                    <h3>Dịch vụ gửi hàng</h3>
                    <p>Quản lý thông tin shop và tạo đơn trong một luồng gọn.</p>
                </article>
                <article class="service-item">
                    <img src="/images/landing/icon3.svg" alt="" />
                    <h3>Dich vu COD</h3>
                    <p>Theo dõi tiền thu hộ và đối soát minh bạch hơn.</p>
                </article>
                <article class="service-item">
                    <img src="/images/landing/icon4.svg" alt="" />
                    <h3>Xử lý vận đơn</h3>
                    <p>Cập nhật trạng thái vận đơn rõ từng mốc nghiệp vụ.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="about-section" id="about">
        <div class="container section-narrow">
            <h2>Về chúng tôi</h2>
            <p class="section-intro">
                LAK hướng tới một giao diện logistics dễ sử dụng hằng ngày: bố cục đơn giản,
                hình ảnh đúng ngữ cảnh và ưu tiên thao tác thực tế thay vì trang trí.
            </p>

            <div class="about-grid">
                <article class="about-card">
                    <img src="/images/landing/hero-banner.png" alt="Nhan vien giao nhan LAK" />
                    <div class="about-copy">
                        <strong>Vận hành rõ ràng</strong>
                        <span>Tập trung vào tạo đơn, tracking và xử lý giao nhận theo một flow dễ quét.</span>
                    </div>
                </article>
                <article class="about-card">
                    <img src="/images/landing/ops-banner.png" alt="He thong kho va xu ly van hanh LAK" />
                    <div class="about-copy">
                        <strong>Sẵn sàng mở rộng</strong>
                        <span>Style này sẽ được dùng tiếp cho tracking, login, shipments và dashboard.</span>
                    </div>
                </article>
            </div>
        </div>
    </section>
</main>
