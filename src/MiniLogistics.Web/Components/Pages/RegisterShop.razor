@page "/register-shop"
@layout MiniLogistics.Web.Components.Layout.LandingLayout
@attribute [AllowAnonymous]

<PageTitle>Đăng ký shop - MiniLogistics</PageTitle>

<main class="register-page">
    <section class="register-hero" aria-label="Đăng ký shop">
        <div class="register-brand">
            <img src="/images/landing%20page/logo.svg" alt="MiniLogistics" />
            <div>
                <strong>MiniLogistics</strong>
                <span>Đăng ký shop</span>
            </div>
        </div>

        <div class="register-copy">
            <h1>Mở shop và bắt đầu tạo vận đơn trong một workspace gọn gàng.</h1>
            <p>
                Tạo tài khoản shop, khai báo địa chỉ lấy hàng mặc định, rồi chuyển thẳng sang luồng tạo vận đơn,
                theo dõi COD và vận hành giao nhận.
            </p>
        </div>

        <div class="register-highlights" aria-label="Điểm nổi bật">
            <article>
                <strong>Thiết lập nhanh</strong>
                <p>Tài khoản, thông tin shop và địa chỉ lấy hàng trong một biểu mẫu.</p>
            </article>
            <article>
                <strong>Vận hành rõ ràng</strong>
                <p>Dashboard, luồng vận đơn và COD nằm trong cùng hệ thống.</p>
            </article>
            <article>
                <strong>Sẵn sàng demo</strong>
                <p>Bố cục phù hợp desktop, laptop và màn hình nhỏ.</p>
            </article>
        </div>
    </section>

    <section class="register-panel" aria-label="Tạo tài khoản shop">
        <div class="panel-head">
            <a class="back-link" href="/login">Quay lại đăng nhập</a>
            <span class="panel-badge">Tài khoản shop</span>
        </div>

        <div class="register-card">
            <div class="card-copy">
                <h2>Tạo tài khoản shop</h2>
                <p>Dùng thông tin liên hệ sẽ quản lý đơn hàng và đối soát COD.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="register-error" role="alert">@UiDisplay.ToErrorMessage(Error)</div>
            }

            <form method="post" action="/auth/register-shop" class="register-form">
                <AntiforgeryToken />

                <div class="form-grid">
                    <label class="field-group" for="full-name">
                        <span>Họ và tên</span>
                        <input id="full-name" name="FullName" autocomplete="name" required maxlength="150" />
                    </label>

                    <label class="field-group" for="email">
                        <span>Email</span>
                        <input id="email" name="Email" type="email" autocomplete="email" required maxlength="256" />
                    </label>

                    <label class="field-group" for="password">
                        <span>Mật khẩu</span>
                        <input id="password" name="Password" type="password" autocomplete="new-password" required minlength="6" maxlength="100" />
                    </label>

                    <label class="field-group" for="phone-number">
                        <span>Số điện thoại</span>
                        <input id="phone-number" name="PhoneNumber" type="tel" autocomplete="tel" required maxlength="20" />
                    </label>

                    <label class="field-group field-span-2" for="shop-name">
                        <span>Tên shop</span>
                        <input id="shop-name" name="ShopName" required maxlength="200" />
                    </label>

                    <label class="field-group" for="province">
                        <span>Tỉnh / Thành</span>
                        <input id="province" name="Province" required maxlength="100" />
                    </label>

                    <label class="field-group" for="ward">
                        <span>Phường / Xã</span>
                        <input id="ward" name="Ward" required maxlength="100" />
                    </label>

                    <label class="field-group field-span-2" for="address-line">
                        <span>Địa chỉ</span>
                        <input id="address-line" name="AddressLine" required maxlength="300" />
                    </label>
                </div>

                <input type="hidden" name="Country" value="Vietnam" />

                <div class="form-actions register-actions">
                    <button type="submit" class="submit-button">Tạo tài khoản</button>
                    <a class="secondary-link" href="/login">Đã có tài khoản?</a>
                </div>
            </form>
        </div>
    </section>
</main>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
}
