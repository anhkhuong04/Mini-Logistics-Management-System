@page "/tracking"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Http
@using MiniLogistics.Application.Shipments.GetPublicTracking
@using MiniLogistics.Domain.Shipments
@inject IGetPublicTrackingService GetPublicTrackingService
@inject IPublicTrackingRateLimiter TrackingRateLimiter
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Tracking</PageTitle>

<div class="tracking-page">
    <div class="page-heading">
        <div>
            <h1>Tra cứu vận đơn</h1>
            <p>Nhập tracking code để xem trạng thái hiện tại và tuyến giao hàng.</p>
        </div>
    </div>

    <div class="tracking-grid">
        <section class="content-card search-card">
            <div class="section-heading">
                <span class="section-icon">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M10.5 4a6.5 6.5 0 0 1 5.1 10.5l4 4-1.4 1.4-4-4A6.5 6.5 0 1 1 10.5 4Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" />
                    </svg>
                </span>
                <h2>Tracking code</h2>
            </div>

            <EditForm Model="Form" OnValidSubmit="HandleSearchAsync" class="tracking-form">
                <DataAnnotationsValidator />

                <div class="form-field">
                    <label for="tracking-code">Mã vận đơn</label>
                    <InputText id="tracking-code" class="form-control" @bind-Value="Form.TrackingCode" />
                    <ValidationMessage For="() => Form.TrackingCode" />
                </div>

                <button class="btn btn-primary search-button" type="submit" disabled="@IsSearching">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M10.5 4a6.5 6.5 0 0 1 5.1 10.5l4 4-1.4 1.4-4-4A6.5 6.5 0 1 1 10.5 4Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" />
                    </svg>
                    <span>@(IsSearching ? "Đang tra cứu..." : "Tra cứu")</span>
                </button>
            </EditForm>
        </section>

        <section class="content-card result-card">
            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="empty-result">
                    <span class="result-icon danger">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm1 15h-2v-2h2v2Zm0-4h-2V7h2v6Z" />
                        </svg>
                    </span>
                    <strong>Không tìm thấy vận đơn</strong>
                    <p>@ErrorMessage</p>
                </div>
            }
            else if (TrackingResult is null)
            {
                <div class="empty-result">
                    <span class="result-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Zm2 1.2v6.6l5 2.8v-6.6L6 8.7Zm7 9.4 5-2.8V8.7l-5 2.8v6.6Zm-6-11L12 10l5-2.9-5-2.8-5 2.8Z" />
                        </svg>
                    </span>
                    <strong>Chưa có dữ liệu tra cứu</strong>
                    <p>Thông tin vận đơn sẽ hiển thị sau khi nhập tracking code hợp lệ.</p>
                </div>
            }
            else
            {
                <div class="tracking-summary">
                    <span>Tracking code</span>
                    <strong>@TrackingResult.TrackingCode</strong>
                    <div class="summary-pills">
                        <span class="status-pill @GetStatusClass(TrackingResult.CurrentStatus)">
                            @FormatStatus(TrackingResult.CurrentStatus)
                        </span>
                        <span class="access-pill @GetAccessClass(TrackingResult.AccessLevel)">
                            @FormatAccessLevel(TrackingResult.AccessLevel)
                        </span>
                    </div>
                </div>

                <dl class="summary-grid">
                    <div>
                        <dt>Ngày tạo</dt>
                        <dd>@FormatDate(TrackingResult.CreatedAtUtc)</dd>
                    </div>
                    <div>
                        <dt>Cập nhật cuối</dt>
                        <dd>@FormatDate(TrackingResult.LastUpdatedAtUtc)</dd>
                    </div>
                    <div>
                        <dt>Từ</dt>
                        <dd>@TrackingResult.PickupProvince</dd>
                    </div>
                    <div>
                        <dt>Đến</dt>
                        <dd>@TrackingResult.DeliveryProvince</dd>
                    </div>
                    <div>
                        <dt>Người gửi</dt>
                        <dd>@DisplayOrHidden(TrackingResult.SenderName)</dd>
                    </div>
                    <div>
                        <dt>Người nhận</dt>
                        <dd>@DisplayOrHidden(TrackingResult.ReceiverName)</dd>
                    </div>
                </dl>

                @if (TrackingResult.AccessLevel == PublicTrackingAccessLevel.Summary)
                {
                    <div class="privacy-panel">
                        <div class="privacy-copy">
                            <strong>Chi tiết đang được ẩn</strong>
                            <p>Xác minh bằng 4 số cuối điện thoại người gửi hoặc người nhận.</p>
                        </div>

                        <EditForm Model="VerificationForm" OnValidSubmit="HandleVerifyAsync" class="verify-form">
                            <DataAnnotationsValidator />

                            <div class="form-field">
                                <label for="phone-last4">4 số cuối điện thoại</label>
                                <InputText id="phone-last4" class="form-control" inputmode="numeric" maxlength="4" @bind-Value="VerificationForm.PhoneLast4" />
                                <ValidationMessage For="() => VerificationForm.PhoneLast4" />
                            </div>

                            <button class="btn btn-secondary verify-button" type="submit" disabled="@IsVerifying">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M12 2 4 5.5V11c0 5 3.4 9.3 8 10.5 4.6-1.2 8-5.5 8-10.5V5.5L12 2Zm0 2.2 6 2.7V11c0 3.9-2.5 7.3-6 8.4-3.5-1.1-6-4.5-6-8.4V6.9l6-2.7Zm3.7 5.1-5 5-2.4-2.4-1.4 1.4 3.8 3.8 6.4-6.4-1.4-1.4Z" />
                                </svg>
                                <span>@(IsVerifying ? "Đang xác minh..." : "Xác minh")</span>
                            </button>
                        </EditForm>

                        @if (!string.IsNullOrWhiteSpace(VerifyMessage))
                        {
                            <p class="inline-message">@VerifyMessage</p>
                        }
                    </div>
                }
                else
                {
                    <dl class="summary-grid detail-grid">
                        <div>
                            <dt>Điện thoại gửi</dt>
                            <dd>@DisplayOrHidden(TrackingResult.SenderPhone)</dd>
                        </div>
                        <div>
                            <dt>Điện thoại nhận</dt>
                            <dd>@DisplayOrHidden(TrackingResult.ReceiverPhone)</dd>
                        </div>
                        <div>
                            <dt>Địa chỉ lấy</dt>
                            <dd>@DisplayOrHidden(TrackingResult.PickupAddress?.FullAddress)</dd>
                        </div>
                        <div>
                            <dt>Địa chỉ giao</dt>
                            <dd>@DisplayOrHidden(TrackingResult.DeliveryAddress?.FullAddress)</dd>
                        </div>
                    </dl>
                }

                <h2 class="timeline-title">Timeline</h2>
                <ol class="timeline">
                    @foreach (var item in TrackingResult.Timeline)
                    {
                        <li>
                            <span class="timeline-dot"></span>
                            <div>
                                <strong>@FormatStatus(item.Status)</strong>
                                <time>@FormatDate(item.ChangedAtUtc)</time>
                            </div>
                        </li>
                    }
                </ol>
            }
        </section>
    </div>
</div>

@code {
    private TrackingFormModel Form { get; set; } = new();

    private TrackingVerificationFormModel VerificationForm { get; set; } = new();

    private bool IsSearching { get; set; }

    private bool IsVerifying { get; set; }

    private string? LoadedQueryCode { get; set; }

    private string? ErrorMessage { get; set; }

    private string? VerifyMessage { get; set; }

    private PublicTrackingResponse? TrackingResult { get; set; }

    [SupplyParameterFromQuery(Name = "code")]
    public string? QueryTrackingCode { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        var normalizedCode = QueryTrackingCode?.Trim();
        if (string.IsNullOrWhiteSpace(normalizedCode)
            || string.Equals(LoadedQueryCode, normalizedCode, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        LoadedQueryCode = normalizedCode;
        Form.TrackingCode = normalizedCode;

        IsSearching = true;
        try
        {
            await SearchAsync(normalizedCode, clearResult: true);
        }
        finally
        {
            IsSearching = false;
        }
    }

    private async Task HandleSearchAsync()
    {
        IsSearching = true;
        try
        {
            await SearchAsync(Form.TrackingCode, clearResult: true);
        }
        finally
        {
            IsSearching = false;
        }
    }

    private async Task HandleVerifyAsync()
    {
        if (TrackingResult is null)
        {
            return;
        }

        IsVerifying = true;
        try
        {
            await SearchAsync(
                TrackingResult.TrackingCode,
                VerificationForm.PhoneLast4,
                clearResult: false);

            if (TrackingResult?.AccessLevel == PublicTrackingAccessLevel.Summary
                && string.IsNullOrWhiteSpace(VerifyMessage))
            {
                VerifyMessage = "4 số cuối không khớp với vận đơn này.";
            }
        }
        finally
        {
            IsVerifying = false;
        }
    }

    private async Task SearchAsync(
        string trackingCode,
        string? phoneLast4 = null,
        bool clearResult = true)
    {
        var normalizedCode = trackingCode.Trim();
        if (clearResult)
        {
            ErrorMessage = null;
            VerifyMessage = null;
            TrackingResult = null;
            VerificationForm.PhoneLast4 = string.Empty;
        }
        else
        {
            ErrorMessage = null;
            VerifyMessage = null;
        }

        if (!TrackingRateLimiter.TryAcquire(GetClientKey(), normalizedCode, out var retryAfter))
        {
            var message = $"Bạn thao tác quá nhanh. Vui lòng thử lại sau {FormatRetryAfter(retryAfter)}.";
            if (clearResult)
            {
                ErrorMessage = message;
            }
            else
            {
                VerifyMessage = message;
            }

            return;
        }

        var result = await GetPublicTrackingService.GetAsync(
            normalizedCode,
            phoneLast4?.Trim());
        if (result.IsFailure)
        {
            var message = UiDisplay.ToErrorMessage(result.Error);
            if (clearResult)
            {
                ErrorMessage = message;
            }
            else
            {
                VerifyMessage = message;
            }

            return;
        }

        TrackingResult = result.Value;
        Form.TrackingCode = result.Value.TrackingCode;
    }

    private string GetClientKey()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        var forwardedFor = httpContext?.Request.Headers["X-Forwarded-For"].FirstOrDefault();
        if (!string.IsNullOrWhiteSpace(forwardedFor))
        {
            return forwardedFor.Split(',')[0].Trim();
        }

        return httpContext?.Connection.RemoteIpAddress?.ToString() ?? "unknown-circuit";
    }

    private static string FormatDate(DateTimeOffset value)
    {
        return UiDisplay.FormatLocalDateTime(value);
    }

    private static string DisplayOrHidden(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "Đã ẩn"
            : value;
    }

    private static string FormatRetryAfter(TimeSpan retryAfter)
    {
        var seconds = Math.Max(1, (int)Math.Ceiling(retryAfter.TotalSeconds));
        return $"{seconds} giây";
    }

    private static string FormatAccessLevel(PublicTrackingAccessLevel accessLevel)
    {
        return accessLevel == PublicTrackingAccessLevel.Verified
            ? "Đã xác minh"
            : "Tóm tắt";
    }

    private static string GetAccessClass(PublicTrackingAccessLevel accessLevel)
    {
        return accessLevel == PublicTrackingAccessLevel.Verified
            ? "verified"
            : "summary";
    }

    private static string FormatStatus(ShipmentStatus status)
    {
        return status switch
        {
            ShipmentStatus.Draft => "Nháp",
            ShipmentStatus.PendingPickup => "Chờ lấy hàng",
            ShipmentStatus.Assigned => "Đã phân công",
            ShipmentStatus.PickingUp => "Đang lấy hàng",
            ShipmentStatus.PickedUp => "Đã lấy hàng",
            ShipmentStatus.InTransit => "Đang vận chuyển",
            ShipmentStatus.Delivering => "Đang giao",
            ShipmentStatus.Delivered => "Đã giao",
            ShipmentStatus.DeliveryFailed => "Giao thất bại",
            ShipmentStatus.Returned => "Đã hoàn",
            ShipmentStatus.Cancelled => "Đã hủy",
            _ => status.ToString()
        };
    }

    private static string GetStatusClass(ShipmentStatus status)
    {
        return status switch
        {
            ShipmentStatus.Delivered => "success",
            ShipmentStatus.Cancelled or ShipmentStatus.DeliveryFailed or ShipmentStatus.Returned => "danger",
            ShipmentStatus.InTransit or ShipmentStatus.Delivering or ShipmentStatus.PickedUp => "info",
            _ => "warning"
        };
    }

    private sealed class TrackingFormModel
    {
        [Required]
        [MaxLength(30)]
        public string TrackingCode { get; set; } = string.Empty;
    }

    private sealed class TrackingVerificationFormModel
    {
        [Required]
        [RegularExpression(@"^\d{4}$", ErrorMessage = "Vui lòng nhập đúng 4 chữ số cuối.")]
        public string PhoneLast4 { get; set; } = string.Empty;
    }
}
