@page "/admin/users"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using System.Security.Claims
@using MiniLogistics.Application.AdminUsers.CreateInternalUser
@using MiniLogistics.Application.AdminUsers.GetAdminUsers
@using MiniLogistics.Application.AdminUsers.SetShipperCapacity
@using MiniLogistics.Application.AdminUsers.SetUserActiveStatus
@using MiniLogistics.Application.Shippers
@using MiniLogistics.Application.Shippers.GetLogisticsHubs
@using MiniLogistics.Application.Shippers.SetShipperWorkingAreas
@using MiniLogistics.Domain.Users
@inject ICreateInternalUserService CreateInternalUserService
@inject IGetAdminUsersService GetAdminUsersService
@inject ISetShipperCapacityService SetShipperCapacityService
@inject ISetUserActiveStatusService SetUserActiveStatusService
@inject IGetLogisticsHubsService GetLogisticsHubsService
@inject ISetShipperWorkingAreasService SetShipperWorkingAreasService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Quan ly nguoi dung - MiniLogistics</PageTitle>

<div class="admin-users-page">
    <header class="admin-hero">
        <div>
            <p class="eyebrow">Quan tri he thong</p>
            <h1>Nguoi dung</h1>
            <p>Quan ly tai khoan noi bo, vai tro van hanh va trang thai truy cap.</p>
        </div>

        <button type="button" class="refresh-button" disabled="@IsLoading" @onclick="RefreshAsync">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 5a7 7 0 1 1-6.3 4H3.5A9 9 0 1 0 6 5.8V3H4v6h6V7H7.4A7 7 0 0 1 12 5Z" />
            </svg>
            <span>Lam moi</span>
        </button>
    </header>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert-box danger" role="alert">@ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <div class="alert-box success" role="status">@SuccessMessage</div>
    }

    @if (IsLoading)
    {
        <section class="admin-panel state-card" aria-live="polite">
            <strong>Dang tai danh sach nguoi dung</strong>
        </section>
    }
    else
    {
        <section class="summary-grid" aria-label="Tom tat nguoi dung">
            <article class="metric-card">
                <span class="metric-icon blue" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm0 2c-4.2 0-7 2.1-7 5v1h14v-1c0-2.9-2.8-5-7-5Z" /></svg>
                </span>
                <span>Tong user</span>
                <strong>@Users.Count.ToString("N0")</strong>
            </article>
            <article class="metric-card">
                <span class="metric-icon green" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="m9.5 16.2-4-4 1.4-1.4 2.6 2.6 7.6-7.6 1.4 1.4-9 9Z" /></svg>
                </span>
                <span>Dang hoat dong</span>
                <strong>@Users.Count(user => user.IsActive).ToString("N0")</strong>
            </article>
            <article class="metric-card">
                <span class="metric-icon amber" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M3 6h11v9h1.4l2-3H21v6h-2a3 3 0 0 1-6 0H9a3 3 0 0 1-6 0H2V8a2 2 0 0 1 1-2Zm2 2v7.8A3 3 0 0 1 8.8 17H13V8H5Zm10 2v5h.6l2-3H19v-2h-4Z" /></svg>
                </span>
                <span>Shipper active</span>
                <strong>@Users.Count(user => IsRole(user, UserRole.Shipper) && user.IsActive).ToString("N0")</strong>
            </article>
            <article class="metric-card">
                <span class="metric-icon slate" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M5 4h14v4H5V4Zm0 6h9v4H5v-4Zm0 6h14v4H5v-4Zm11-6h3v4h-3v-4Z" /></svg>
                </span>
                <span>Operator</span>
                <strong>@Users.Count(user => IsRole(user, UserRole.Operator)).ToString("N0")</strong>
            </article>
        </section>

        <section class="admin-panel create-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Tai khoan noi bo</p>
                    <h2>Tao shipper/operator</h2>
                </div>
            </div>

            <form class="create-user-form" @onsubmit="CreateUserAsync" @onsubmit:preventDefault="true">
                <label class="field-group" for="admin-user-full-name">
                    <span>Ho ten</span>
                    <input id="admin-user-full-name" maxlength="150" required @bind="CreateFullName" @bind:event="oninput" />
                </label>

                <label class="field-group" for="admin-user-email">
                    <span>Email</span>
                    <input id="admin-user-email" type="email" maxlength="256" required @bind="CreateEmail" @bind:event="oninput" />
                </label>

                <label class="field-group" for="admin-user-phone">
                    <span>So dien thoai</span>
                    <input id="admin-user-phone" type="tel" maxlength="20" required @bind="CreatePhoneNumber" @bind:event="oninput" />
                </label>

                <label class="field-group" for="admin-user-password">
                    <span>Mat khau</span>
                    <input id="admin-user-password" type="password" minlength="6" maxlength="100" required @bind="CreatePassword" @bind:event="oninput" />
                </label>

                <label class="field-group" for="admin-user-role">
                    <span>Vai tro</span>
                    <select id="admin-user-role" @bind="CreateRole">
                        <option value="Shipper">Shipper</option>
                        <option value="Operator">Operator</option>
                    </select>
                </label>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@IsCreating">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M11 5h2v6h6v2h-6v6h-2v-6H5v-2h6V5Z" />
                        </svg>
                        @(IsCreating ? "Dang tao..." : "Tao tai khoan")
                    </button>
                </div>
            </form>
        </section>

        <section class="admin-panel working-area-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Dieu phoi hub</p>
                    <h2>Khu vuc lam viec cua shipper</h2>
                </div>
                <span class="section-count">@Hubs.Count.ToString("N0") hub active</span>
            </div>

            @if (ShipperUsers.Count == 0)
            {
                <div class="state-card compact">
                    <strong>Chua co shipper</strong>
                    <p>Tao tai khoan role Shipper truoc khi gan khu vuc lam viec.</p>
                </div>
            }
            else if (Hubs.Count == 0)
            {
                <div class="state-card compact">
                    <strong>Chua co hub active</strong>
                    <p>Can seed hoac tao hub truoc khi gan khu vuc lam viec cho shipper.</p>
                </div>
            }
            else
            {
                <div class="working-area-layout">
                    <label class="field-group shipper-picker" for="working-area-shipper">
                        <span>Shipper</span>
                        <select id="working-area-shipper" value="@SelectedShipperForAreaValue" @onchange="SelectAreaShipper">
                            @foreach (var shipper in ShipperUsers)
                            {
                                <option value="@shipper.UserId">@FormatShipperOption(shipper)</option>
                            }
                        </select>
                    </label>

                    @if (SelectedAreaShipper is not null)
                    {
                        <div class="selected-shipper-summary">
                            <strong>@SelectedAreaShipper.FullName</strong>
                            <span>@SelectedWorkingAreaHubIds.Count.ToString("N0") hub duoc chon - @FormatCapacity(SelectedAreaShipper)</span>
                        </div>

                        <form class="capacity-form" @onsubmit="SaveCapacityAsync" @onsubmit:preventDefault="true">
                            <label class="availability-toggle" for="shipper-available">
                                <input id="shipper-available"
                                       type="checkbox"
                                       @bind="SelectedShipperIsAvailableForAssignment" />
                                <span>Cho phep auto assign</span>
                            </label>

                            <label class="field-group capacity-input" for="shipper-max-active">
                                <span>Max active shipments</span>
                                <input id="shipper-max-active"
                                       type="number"
                                       min="1"
                                       max="200"
                                       required
                                       @bind="SelectedShipperMaxActiveShipments"
                                       @bind:event="oninput" />
                            </label>

                            <button type="submit" class="primary-button" disabled="@IsSavingCapacity">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M5 4h12l2 2v14H5V4Zm2 2v12h10V7.2L15.8 6H7Zm2 1h5v4H9V7Zm0 8h6v2H9v-2Z" />
                                </svg>
                                @(IsSavingCapacity ? "Dang luu..." : "Luu capacity")
                            </button>
                        </form>
                    }

                    <div class="hub-picker-grid" role="group" aria-label="Danh sach hub lam viec">
                        @foreach (var hub in Hubs)
                        {
                            var checkboxId = $"hub-{hub.HubId}";
                            <label class="hub-option @(IsHubSelected(hub.HubId) ? "selected" : null)" for="@checkboxId">
                                <input id="@checkboxId"
                                       type="checkbox"
                                       checked="@IsHubSelected(hub.HubId)"
                                       @onchange="eventArgs => ToggleHubSelection(hub.HubId, eventArgs.Value)" />
                                <span>
                                    <strong>@hub.Province</strong>
                                    <small>@hub.Code - @(hub.IsRegionalSortingHub ? "Sorting hub" : "Province hub")</small>
                                </span>
                            </label>
                        }
                    </div>

                    <div class="form-actions">
                        <button type="button" class="primary-button" disabled="@IsSavingWorkingAreas" @onclick="SaveWorkingAreasAsync">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M5 4h12l2 2v14H5V4Zm2 2v12h10V7.2L15.8 6H7Zm2 1h5v4H9V7Zm0 8h6v2H9v-2Z" />
                            </svg>
                            @(IsSavingWorkingAreas ? "Dang luu..." : "Luu khu vuc")
                        </button>
                    </div>
                </div>
            }
        </section>

        <section class="admin-panel users-section">
            <div class="panel-heading users-heading">
                <div>
                    <p class="eyebrow">Danh sach</p>
                    <h2>Nguoi dung he thong</h2>
                </div>
                <span class="section-count">@VisibleUsers.Count.ToString("N0") / @Users.Count.ToString("N0") user</span>
            </div>

            <div class="table-toolbar">
                <label class="search-field" for="admin-user-search">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M10.5 4a6.5 6.5 0 0 1 5.1 10.5l4 4-1.4 1.4-4-4A6.5 6.5 0 1 1 10.5 4Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" />
                    </svg>
                    <input id="admin-user-search" placeholder="Tim theo ten, email, sdt" @bind="SearchText" @bind:event="oninput" />
                </label>

                <label class="filter-field" for="admin-role-filter">
                    <span>Vai tro</span>
                    <select id="admin-role-filter" @bind="RoleFilter">
                        <option value="All">Tat ca</option>
                        <option value="Admin">Admin</option>
                        <option value="Operator">Operator</option>
                        <option value="Shop">Shop</option>
                        <option value="Shipper">Shipper</option>
                    </select>
                </label>
            </div>

            @if (VisibleUsers.Count == 0)
            {
                <div class="state-card compact">
                    <strong>Khong co user phu hop</strong>
                    <p>Thu doi tu khoa tim kiem hoac bo loc vai tro.</p>
                </div>
            }
            else
            {
                <div class="table-shell">
                    <table class="users-table">
                        <thead>
                            <tr>
                                <th>Nguoi dung</th>
                                <th>Lien he</th>
                                <th>Vai tro</th>
                                <th>Khu vuc</th>
                                <th>Dieu phoi</th>
                                <th>Trang thai</th>
                                <th>Ngay tao</th>
                                <th>Thao tac</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in VisibleUsers)
                            {
                                <tr>
                                    <td data-label="Nguoi dung">
                                        <div class="user-cell">
                                            <span class="user-avatar">@GetInitials(user.FullName)</span>
                                            <span>
                                                <strong>@user.FullName</strong>
                                                <small>ID @user.UserId.ToString()[..8]</small>
                                            </span>
                                        </div>
                                    </td>
                                    <td data-label="Lien he">
                                        <strong>@user.Email</strong>
                                        @if (!string.IsNullOrWhiteSpace(user.PhoneNumber))
                                        {
                                            <small>@user.PhoneNumber</small>
                                        }
                                    </td>
                                    <td data-label="Vai tro">
                                        <div class="role-list">
                                            @foreach (var role in user.Roles)
                                            {
                                                <span class="role-pill">@role</span>
                                            }
                                        </div>
                                    </td>
                                    <td data-label="Khu vuc">
                                        @if (IsRole(user, UserRole.Shipper))
                                        {
                                            <div class="area-list">
                                                @if (user.WorkingAreas.Count == 0)
                                                {
                                                    <span class="empty-area">Chua gan hub</span>
                                                }
                                                else
                                                {
                                                    @foreach (var area in user.WorkingAreas)
                                                    {
                                                        <span class="area-pill" title="@area.HubName">@area.Province</span>
                                                    }
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="locked-note">Khong ap dung</span>
                                        }
                                    </td>
                                    <td data-label="Dieu phoi">
                                        @if (IsRole(user, UserRole.Shipper))
                                        {
                                            <div class="capacity-list">
                                                <span class="capacity-pill @(user.IsAvailableForAssignment ? "available" : "paused")">
                                                    @(user.IsAvailableForAssignment ? "Nhan auto" : "Tam ngung")
                                                </span>
                                                <small>@FormatCapacity(user)</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="locked-note">Khong ap dung</span>
                                        }
                                    </td>
                                    <td data-label="Trang thai">
                                        <span class="status-pill @(user.IsActive ? "active" : "inactive")">
                                            @(user.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td data-label="Ngay tao">@FormatDate(user.CreatedAtUtc)</td>
                                    <td data-label="Thao tac">
                                        @if (CanToggleUser(user))
                                        {
                                            <button type="button"
                                                    class="toggle-button @(user.IsActive ? "danger" : "success")"
                                                    disabled="@IsToggling(user.UserId)"
                                                    @onclick="() => ToggleUserAsync(user)">
                                                @GetToggleButtonText(user)
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="locked-note">Chi xem</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</div>

@code {
    private bool IsLoading { get; set; } = true;

    private bool IsCreating { get; set; }

    private bool IsSavingWorkingAreas { get; set; }

    private bool IsSavingCapacity { get; set; }

    private Guid? TogglingUserId { get; set; }

    private Guid? SelectedShipperForAreaId { get; set; }

    private string? ErrorMessage { get; set; }

    private string? SuccessMessage { get; set; }

    private IReadOnlyList<GetAdminUserResponse> Users { get; set; } = [];

    private IReadOnlyList<LogisticsHubResponse> Hubs { get; set; } = [];

    private HashSet<Guid> SelectedWorkingAreaHubIds { get; set; } = [];

    private bool SelectedShipperIsAvailableForAssignment { get; set; } = true;

    private int SelectedShipperMaxActiveShipments { get; set; } = 30;

    private string SearchText { get; set; } = string.Empty;

    private string RoleFilter { get; set; } = "All";

    private string CreateFullName { get; set; } = string.Empty;

    private string CreateEmail { get; set; } = string.Empty;

    private string CreatePhoneNumber { get; set; } = string.Empty;

    private string CreatePassword { get; set; } = string.Empty;

    private string CreateRole { get; set; } = nameof(UserRole.Shipper);

    private IReadOnlyList<GetAdminUserResponse> VisibleUsers => Users
        .Where(MatchesFilters)
        .ToList();

    private IReadOnlyList<GetAdminUserResponse> ShipperUsers => Users
        .Where(user => IsRole(user, UserRole.Shipper))
        .OrderBy(user => user.FullName)
        .ThenBy(user => user.Email)
        .ToList();

    private GetAdminUserResponse? SelectedAreaShipper => ShipperUsers
        .FirstOrDefault(user => user.UserId == SelectedShipperForAreaId);

    private string SelectedShipperForAreaValue => SelectedShipperForAreaId?.ToString() ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(clearMessages: true);
    }

    private async Task RefreshAsync()
    {
        await LoadAsync(clearMessages: true);
    }

    private async Task LoadAsync(bool clearMessages)
    {
        IsLoading = true;
        ErrorMessage = null;

        if (clearMessages)
        {
            SuccessMessage = null;
        }

        var adminUserId = await GetCurrentUserIdAsync();
        if (adminUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        var result = await GetAdminUsersService.GetAsync(adminUserId.Value);
        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            IsLoading = false;
            return;
        }

        var hubsResult = await GetLogisticsHubsService.GetAsync(activeOnly: true);
        if (hubsResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(hubsResult.Error);
            IsLoading = false;
            return;
        }

        Users = result.Value;
        Hubs = hubsResult.Value;
        SyncSelectedAreaShipper();
        IsLoading = false;
    }

    private async Task CreateUserAsync()
    {
        ErrorMessage = null;
        SuccessMessage = null;

        var adminUserId = await GetCurrentUserIdAsync();
        if (adminUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        IsCreating = true;

        var result = await CreateInternalUserService.CreateAsync(new CreateInternalUserCommand(
            adminUserId.Value,
            CreateFullName,
            CreateEmail,
            CreatePhoneNumber,
            CreatePassword,
            CreateRole));

        IsCreating = false;

        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            return;
        }

        SuccessMessage = $"Da tao {result.Value.Role} {result.Value.FullName}.";
        ClearCreateForm();
        await LoadAsync(clearMessages: false);
    }

    private void SelectAreaShipper(ChangeEventArgs args)
    {
        SelectedShipperForAreaId = Guid.TryParse(args.Value?.ToString(), out var shipperId)
            ? shipperId
            : null;
        SyncSelectedWorkingAreaHubIds();
        SyncSelectedCapacity();
    }

    private void ToggleHubSelection(Guid hubId, object? value)
    {
        var isSelected = value is bool boolValue && boolValue;
        if (isSelected)
        {
            SelectedWorkingAreaHubIds.Add(hubId);
            return;
        }

        SelectedWorkingAreaHubIds.Remove(hubId);
    }

    private async Task SaveWorkingAreasAsync()
    {
        ErrorMessage = null;
        SuccessMessage = null;

        if (SelectedAreaShipper is null)
        {
            ErrorMessage = "Vui long chon shipper truoc khi luu khu vuc.";
            return;
        }

        var adminUserId = await GetCurrentUserIdAsync();
        if (adminUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        IsSavingWorkingAreas = true;

        var result = await SetShipperWorkingAreasService.SetAsync(new SetShipperWorkingAreasCommand(
            adminUserId.Value,
            SelectedAreaShipper.UserId,
            SelectedWorkingAreaHubIds
                .OrderBy(hubId => hubId)
                .Select(hubId => new SetShipperWorkingAreaItem(hubId))
                .ToList()));

        IsSavingWorkingAreas = false;

        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            return;
        }

        SuccessMessage = $"Da cap nhat khu vuc lam viec cho {SelectedAreaShipper.FullName}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task SaveCapacityAsync()
    {
        ErrorMessage = null;
        SuccessMessage = null;

        if (SelectedAreaShipper is null)
        {
            ErrorMessage = "Vui long chon shipper truoc khi luu capacity.";
            return;
        }

        var adminUserId = await GetCurrentUserIdAsync();
        if (adminUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        IsSavingCapacity = true;

        var result = await SetShipperCapacityService.SetAsync(new SetShipperCapacityCommand(
            adminUserId.Value,
            SelectedAreaShipper.UserId,
            SelectedShipperIsAvailableForAssignment,
            SelectedShipperMaxActiveShipments));

        IsSavingCapacity = false;

        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            return;
        }

        SuccessMessage = $"Da cap nhat capacity cho {SelectedAreaShipper.FullName}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task ToggleUserAsync(GetAdminUserResponse user)
    {
        ErrorMessage = null;
        SuccessMessage = null;

        var adminUserId = await GetCurrentUserIdAsync();
        if (adminUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        TogglingUserId = user.UserId;

        var targetActiveStatus = !user.IsActive;
        var result = await SetUserActiveStatusService.SetAsync(new SetUserActiveStatusCommand(
            adminUserId.Value,
            user.UserId,
            targetActiveStatus));

        TogglingUserId = null;

        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            return;
        }

        SuccessMessage = targetActiveStatus
            ? $"Da kich hoat {user.FullName}."
            : $"Da khoa {user.FullName}.";

        await LoadAsync(clearMessages: false);
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userIdValue = authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        return Guid.TryParse(userIdValue, out var userId)
            ? userId
            : null;
    }

    private void ClearCreateForm()
    {
        CreateFullName = string.Empty;
        CreateEmail = string.Empty;
        CreatePhoneNumber = string.Empty;
        CreatePassword = string.Empty;
        CreateRole = nameof(UserRole.Shipper);
    }

    private bool IsToggling(Guid userId)
    {
        return TogglingUserId == userId;
    }

    private bool IsHubSelected(Guid hubId)
    {
        return SelectedWorkingAreaHubIds.Contains(hubId);
    }

    private void SyncSelectedAreaShipper()
    {
        if (ShipperUsers.Count == 0)
        {
            SelectedShipperForAreaId = null;
            SelectedWorkingAreaHubIds = [];
            SelectedShipperIsAvailableForAssignment = true;
            SelectedShipperMaxActiveShipments = 30;
            return;
        }

        if (SelectedShipperForAreaId is null
            || ShipperUsers.All(user => user.UserId != SelectedShipperForAreaId.Value))
        {
            SelectedShipperForAreaId = ShipperUsers[0].UserId;
        }

        SyncSelectedWorkingAreaHubIds();
        SyncSelectedCapacity();
    }

    private void SyncSelectedWorkingAreaHubIds()
    {
        SelectedWorkingAreaHubIds = SelectedAreaShipper?.WorkingAreas
            .Where(area => area.IsActive)
            .Select(area => area.HubId)
            .ToHashSet() ?? [];
    }

    private void SyncSelectedCapacity()
    {
        SelectedShipperIsAvailableForAssignment = SelectedAreaShipper?.IsAvailableForAssignment ?? true;
        SelectedShipperMaxActiveShipments = SelectedAreaShipper?.MaxActiveShipments ?? 30;
    }

    private static bool CanToggleUser(GetAdminUserResponse user)
    {
        return IsRole(user, UserRole.Shipper)
            || IsRole(user, UserRole.Operator);
    }

    private string GetToggleButtonText(GetAdminUserResponse user)
    {
        if (IsToggling(user.UserId))
        {
            return user.IsActive ? "Dang khoa..." : "Dang kich hoat...";
        }

        return user.IsActive ? "Khoa" : "Kich hoat";
    }

    private static bool IsRole(GetAdminUserResponse user, UserRole role)
    {
        return user.Roles.Contains(role.ToString(), StringComparer.OrdinalIgnoreCase);
    }

    private static string FormatShipperOption(GetAdminUserResponse shipper)
    {
        return string.IsNullOrWhiteSpace(shipper.PhoneNumber)
            ? $"{shipper.FullName} - {shipper.Email}"
            : $"{shipper.FullName} - {shipper.PhoneNumber}";
    }

    private static string FormatCapacity(GetAdminUserResponse shipper)
    {
        return $"max {shipper.MaxActiveShipments:N0} don active";
    }

    private bool MatchesFilters(GetAdminUserResponse user)
    {
        var matchesRole = RoleFilter == "All"
            || user.Roles.Contains(RoleFilter, StringComparer.OrdinalIgnoreCase);
        if (!matchesRole)
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(SearchText))
        {
            return true;
        }

        var keyword = SearchText.Trim();
        return user.FullName.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || user.Email.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || (user.PhoneNumber?.Contains(keyword, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private static string GetInitials(string fullName)
    {
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0)
        {
            return "U";
        }

        var initials = parts.Length == 1
            ? parts[0][0].ToString()
            : string.Concat(parts[0][0], parts[^1][0]);

        return initials.ToUpperInvariant();
    }

    private static string FormatDate(DateTimeOffset value)
    {
        return UiDisplay.FormatLocalDateTime(value);
    }
}
