@page "/operations/assignments"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Operator")]
@using System.Security.Claims
@using MiniLogistics.Application.CashOnDelivery.GetCodSettlementCandidates
@using MiniLogistics.Application.CashOnDelivery.MarkCodCollected
@using MiniLogistics.Application.CashOnDelivery.MarkCodSettled
@using MiniLogistics.Application.Shipments
@using MiniLogistics.Application.Shipments.AssignShipperToShipment
@using MiniLogistics.Application.Shipments.AutoAssignShipment
@using MiniLogistics.Application.Shipments.BulkRetryAutoAssignment
@using MiniLogistics.Application.Shipments.CancelShipmentAssignment
@using MiniLogistics.Application.Shipments.GetOperationsShipments
@using MiniLogistics.Application.Shipments.GetPendingPickupShipments
@using MiniLogistics.Application.Shipments.ReassignShipment
@using MiniLogistics.Application.Shipments.UpdateShipmentStatus
@using MiniLogistics.Application.Shippers.GetActiveShippers
@using MiniLogistics.Domain.CashOnDelivery
@using MiniLogistics.Domain.Shipments
@inject IAssignShipperToShipmentService AssignShipperToShipmentService
@inject IAutoAssignShipmentService AutoAssignShipmentService
@inject IBulkRetryAutoAssignmentService BulkRetryAutoAssignmentService
@inject ICancelShipmentAssignmentService CancelShipmentAssignmentService
@inject IGetCodSettlementCandidatesService GetCodSettlementCandidatesService
@inject IGetActiveShippersService GetActiveShippersService
@inject IGetOperationsShipmentsService GetOperationsShipmentsService
@inject IGetPendingPickupShipmentsService GetPendingPickupShipmentsService
@inject IMarkCodCollectedService MarkCodCollectedService
@inject IMarkCodSettledService MarkCodSettledService
@inject IReassignShipmentService ReassignShipmentService
@inject IUpdateShipmentStatusService UpdateShipmentStatusService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Điều phối vận hành - MiniLogistics</PageTitle>

<div class="operations-assignments-page">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Vận hành</p>
            <h1>Điều phối vận hành</h1>
            <p>Phân công shipper, theo dõi đơn đang xử lý và hỗ trợ cập nhật trạng thái hoặc COD khi cần.</p>
        </div>

        <button type="button" class="refresh-button" disabled="@IsLoading" @onclick="RefreshAsync">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 5a7 7 0 1 1-6.3 4H3.5A9 9 0 1 0 6 5.8V3H4v6h6V7H7.4A7 7 0 0 1 12 5Z" />
            </svg>
            <span>Làm mới</span>
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert-box danger" role="alert">@ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <div class="alert-box success" role="status">@SuccessMessage</div>
    }

    @if (IsLoading)
    {
        <section class="content-card state-card" aria-live="polite">
            <span class="state-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2a10 10 0 1 0 10 10h-2a8 8 0 1 1-8-8V2Z" />
                </svg>
            </span>
            <strong>Đang tải workspace điều phối</strong>
        </section>
    }
    else
    {
        <section class="content-card">
            <div class="summary-strip" aria-label="Tóm tắt điều phối">
                <article>
                    <span>Chờ phân công</span>
                    <strong>@PendingTotalCount.ToString("N0")</strong>
                </article>
                <article>
                    <span>Đang vận hành</span>
                    <strong>@OperationsTotalCount.ToString("N0")</strong>
                </article>
                <article>
                    <span>Shipper active</span>
                    <strong>@ActiveShippers.Count.ToString("N0")</strong>
                </article>
                <article>
                    <span>COD cần hỗ trợ</span>
                    <strong>@OperationsShipments.Count(shipment => CanMarkCodCollected(shipment)).ToString("N0")</strong>
                </article>
                @if (IsAdminUser)
                {
                    <article>
                        <span>COD chờ đối soát</span>
                        <strong>@CodSettlementCandidates.Count.ToString("N0")</strong>
                    </article>
                }
            </div>
        </section>

        <section class="content-card operations-filter-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Bo loc</p>
                    <h2>Tim va phan trang workspace</h2>
                </div>
                <button type="button" class="retry-button" disabled="@IsLoading" @onclick="ApplyFiltersAsync">Ap dung</button>
            </div>

            <div class="filter-grid">
                <label class="filter-field" for="operations-search">
                    <span>Search</span>
                    <input id="operations-search" placeholder="Tracking, nguoi nhan, sdt" @bind="FilterSearchText" @bind:event="oninput" />
                </label>
                <label class="filter-field" for="operations-province">
                    <span>Province</span>
                    <input id="operations-province" placeholder="Pickup/delivery province" @bind="FilterProvince" @bind:event="oninput" />
                </label>
                <label class="filter-field" for="operations-status">
                    <span>Status</span>
                    <select id="operations-status" @bind="FilterStatus">
                        <option value="All">Tat ca</option>
                        @foreach (var status in OperationStatusFilterOptions)
                        {
                            <option value="@status">@FormatStatus(status)</option>
                        }
                    </select>
                </label>
                <label class="filter-field" for="operations-cod-status">
                    <span>COD</span>
                    <select id="operations-cod-status" @bind="FilterCodStatus">
                        <option value="All">Tat ca</option>
                        <option value="@CodStatus.PendingCollection">Cho thu</option>
                        <option value="@CodStatus.Collected">Da thu</option>
                        <option value="@CodStatus.Settled">Da doi soat</option>
                    </select>
                </label>
                <label class="filter-field" for="operations-shipper">
                    <span>Shipper id</span>
                    <input id="operations-shipper" placeholder="Guid" @bind="FilterShipperIdText" @bind:event="oninput" />
                </label>
                <label class="filter-field" for="operations-from">
                    <span>Tu ngay</span>
                    <input id="operations-from" type="date" value="@FilterFromDateText" @onchange="OnFilterFromChanged" />
                </label>
                <label class="filter-field" for="operations-to">
                    <span>Den ngay</span>
                    <input id="operations-to" type="date" value="@FilterToDateText" @onchange="OnFilterToChanged" />
                </label>
                <label class="filter-field" for="operations-min-cod">
                    <span>Min COD</span>
                    <input id="operations-min-cod" inputmode="decimal" @bind="FilterMinCodText" @bind:event="oninput" />
                </label>
                <label class="filter-field" for="operations-max-cod">
                    <span>Max COD</span>
                    <input id="operations-max-cod" inputmode="decimal" @bind="FilterMaxCodText" @bind:event="oninput" />
                </label>
                <label class="sla-toggle" for="operations-sla-only">
                    <input id="operations-sla-only" type="checkbox" @bind="FilterSlaOnly" />
                    <span>Chi hien SLA can chu y</span>
                </label>
            </div>
        </section>

        <section class="content-card workspace-section">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Phân công</p>
                    <h2>Đơn chờ phân công</h2>
                </div>
                <span class="section-count">@PendingTotalCount.ToString("N0") đơn</span>
            </div>

            <div class="bulk-toolbar">
                <span>@SelectedPendingShipmentIds.Count.ToString("N0") don da chon</span>
                <button type="button" class="retry-button" disabled="@(PendingShipments.Count == 0)" @onclick="SelectVisiblePendingShipments">
                    Chon trang nay
                </button>
                <button type="button" class="retry-button" disabled="@(SelectedPendingShipmentIds.Count == 0)" @onclick="ClearPendingSelection">
                    Bo chon
                </button>
                <button type="button" class="assign-button" disabled="@(SelectedPendingShipmentIds.Count == 0 || IsBulkRetrying)" @onclick="BulkRetryAutoAssignAsync">
                    @(IsBulkRetrying ? "Dang bulk retry..." : "Bulk retry auto")
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(BulkRetryMessage))
            {
                <div class="alert-box warning" role="status">@BulkRetryMessage</div>
            }

            @if (PendingShipments.Count == 0)
            {
                <div class="state-card compact">
                    <span class="state-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Zm2 1.2v6.6l5 2.8v-6.6L6 8.7Zm7 9.4 5-2.8V8.7l-5 2.8v6.6Zm-6-11L12 10l5-2.9-5-2.8-5 2.8Z" />
                        </svg>
                    </span>
                    <strong>Không có đơn PendingPickup</strong>
                    <p>Đơn shop mới tạo ở trạng thái PendingPickup sẽ xuất hiện tại đây.</p>
                </div>
            }
            else
            {
                @if (ActiveShippers.Count == 0)
                {
                    <div class="alert-box warning" role="status">
                        Chưa có shipper active. Các đơn PendingPickup vẫn được giữ lại để Operations theo dõi và retry sau.
                    </div>
                }

                <div class="table-shell">
                    <table class="assignments-table pending-table">
                        <thead>
                            <tr>
                                <th>Mã vận đơn</th>
                                <th>Người nhận</th>
                                <th>Tuyến</th>
                                <th>COD</th>
                                <th>Phí ship</th>
                                <th>Ngày tạo</th>
                                <th>Fallback</th>
                                <th>Shipper</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var shipment in PendingShipments)
                            {
                                var insight = GetPendingInsight(shipment);
                                var shipperOptions = GetShipperOptions(shipment, insight);
                                var matchedOptions = shipperOptions.Where(option => option.MatchesPickupArea).ToList();
                                var overrideOptions = shipperOptions.Where(option => !option.MatchesPickupArea).ToList();

                                <tr>
                                    <td><span class="tracking-code">@shipment.TrackingCode</span></td>
                                    <td>@shipment.ReceiverName</td>
                                    <td>
                                        <span class="route-text">@shipment.PickupProvince</span>
                                        <svg class="route-arrow" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="m13 5 7 7-7 7-1.4-1.4 4.6-4.6H4v-2h12.2l-4.6-4.6L13 5Z" />
                                        </svg>
                                        <span class="route-text">@shipment.DeliveryProvince</span>
                                    </td>
                                    <td>@FormatMoney(shipment.CodAmount, shipment.Currency)</td>
                                    <td>@FormatMoney(shipment.ShippingFeeAmount, shipment.Currency)</td>
                                    <td>@FormatDate(shipment.CreatedAtUtc)</td>
                                    <td>
                                        <span class="fallback-pill @(insight.HasMatchedShippers ? "info" : "warning")">
                                            @(insight.HasMatchedShippers ? "Có ứng viên" : "Cần manual")
                                        </span>
                                        <small class="fallback-reason">@insight.FallbackReason</small>
                                        @if (shipment.IsSlaOverdue)
                                        {
                                            <small class="sla-badge">Qua SLA pending pickup</small>
                                        }
                                    </td>
                                    <td>
                                        <label class="sr-only" for="@($"shipper-{shipment.ShipmentId}")">Chọn shipper</label>
                                        <select id="@($"shipper-{shipment.ShipmentId}")"
                                                class="@GetSelectClass(shipment.ShipmentId)"
                                                value="@GetSelectedShipperValue(shipment.ShipmentId)"
                                                disabled="@(ActiveShippers.Count == 0 || IsPendingActionBusy(shipment.ShipmentId))"
                                                @onchange="eventArgs => SelectShipper(shipment, eventArgs.Value?.ToString())">
                                            <option value="">Chọn shipper</option>
                                            @if (matchedOptions.Count > 0)
                                            {
                                                <optgroup label="Phù hợp khu vực pickup">
                                                    @foreach (var option in matchedOptions)
                                                    {
                                                        <option value="@option.Shipper.UserId">@FormatShipperOption(option)</option>
                                                    }
                                                </optgroup>
                                            }
                                            @if (overrideOptions.Count > 0)
                                            {
                                                <optgroup label="Manual override">
                                                    @foreach (var option in overrideOptions)
                                                    {
                                                        <option value="@option.Shipper.UserId">@FormatShipperOption(option)</option>
                                                    }
                                                </optgroup>
                                            }
                                        </select>
                                        @if (TryGetSelectedShipper(shipment.ShipmentId, out var selectedShipper))
                                        {
                                            <p class="shipper-meta @GetSelectedShipperMetaClass(shipment, selectedShipper)">
                                                @FormatSelectedShipperMeta(shipment, selectedShipper)
                                            </p>
                                        }
                                        else
                                        {
                                            <p class="shipper-meta">@FormatDefaultShipperMeta(shipment, matchedOptions.Count)</p>
                                        }
                                        @if (RowMessages.TryGetValue(shipment.ShipmentId, out var rowMessage))
                                        {
                                            <p class="row-message @rowMessage.Kind">@rowMessage.Text</p>
                                        }
                                    </td>
                                    <td>
                                        <div class="assignment-actions">
                                            <label class="bulk-select">
                                                <input type="checkbox"
                                                       checked="@SelectedPendingShipmentIds.Contains(shipment.ShipmentId)"
                                                       @onchange="eventArgs => TogglePendingSelection(shipment.ShipmentId, eventArgs.Value)" />
                                                <span>Chon bulk</span>
                                            </label>
                                            <button type="button"
                                                    class="retry-button"
                                                    disabled="@IsPendingActionBusy(shipment.ShipmentId)"
                                                    @onclick="() => RetryAutoAssignAsync(shipment)">
                                                @(IsRetrying(shipment.ShipmentId) ? "Đang retry..." : "Retry auto")
                                            </button>
                                            <button type="button"
                                                    class="assign-button"
                                                    disabled="@IsPendingActionBusy(shipment.ShipmentId)"
                                                    @onclick="() => AssignAsync(shipment)">
                                                @(IsAssigning(shipment.ShipmentId) ? "Đang phân công..." : "Phân công")
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="pagination-bar">
                    <span>Trang @PendingPageNumber.ToString("N0") / @PendingTotalPages.ToString("N0")</span>
                    <button type="button" class="retry-button" disabled="@(PendingPageNumber <= 1)" @onclick="PreviousPendingPageAsync">Truoc</button>
                    <button type="button" class="retry-button" disabled="@(PendingPageNumber >= PendingTotalPages)" @onclick="NextPendingPageAsync">Sau</button>
                </div>
            }
        </section>

        <section class="content-card workspace-section">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Theo dõi vận hành</p>
                    <h2>Đơn đang được xử lý</h2>
                </div>
                <span class="section-count">@OperationsShipments.Count.ToString("N0") đơn</span>
            </div>

            @if (OperationsShipments.Count == 0)
            {
                <div class="state-card compact">
                    <span class="state-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Zm2 1.2v6.6l5 2.8v-6.6L6 8.7Zm7 9.4 5-2.8V8.7l-5 2.8v6.6Zm-6-11L12 10l5-2.9-5-2.8-5 2.8Z" />
                        </svg>
                    </span>
                    <strong>Không có đơn đang vận hành</strong>
                    <p>Đơn sau khi assign sẽ xuất hiện tại đây để operator theo dõi.</p>
                </div>
            }
            else
            {
                <div class="table-shell">
                    <table class="assignments-table operations-table">
                        <thead>
                            <tr>
                                <th>Mã vận đơn</th>
                                <th>Người nhận</th>
                                <th>Shipper</th>
                                <th>Trạng thái</th>
                                <th>COD</th>
                                <th>Tuyến giao</th>
                                <th>Hỗ trợ vận hành</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var shipment in OperationsShipments)
                            {
                                <tr>
                                    <td><span class="tracking-code">@shipment.TrackingCode</span></td>
                                    <td>
                                        <strong>@shipment.ReceiverName</strong>
                                        <small>@shipment.ReceiverPhone</small>
                                    </td>
                                    <td>
                                        <strong>@FormatAssignedShipper(shipment)</strong>
                                        @if (!string.IsNullOrWhiteSpace(shipment.ActiveShipperPhone))
                                        {
                                            <small>@shipment.ActiveShipperPhone</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="status-pill @GetStatusClass(shipment.Status)">@FormatStatus(shipment.Status)</span>
                                        @if (shipment.IsSlaOverdue)
                                        {
                                            <small class="sla-badge">Can chu y SLA</small>
                                        }
                                    </td>
                                    <td>
                                        <strong>@FormatMoney(shipment.CodAmount, shipment.Currency)</strong>
                                        <small class="cod-pill @GetCodStatusClass(shipment.CodStatus)">@FormatCodStatus(shipment.CodStatus)</small>
                                    </td>
                                    <td>
                                        <span class="route-text">@shipment.PickupAddress.Province</span>
                                        <svg class="route-arrow" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="m13 5 7 7-7 7-1.4-1.4 4.6-4.6H4v-2h12.2l-4.6-4.6L13 5Z" />
                                        </svg>
                                        <span class="route-text">@shipment.DeliveryAddress.Province</span>
                                    </td>
                                    <td>
                                        <div class="operations-actions">
                                            @if (CanMarkCodCollected(shipment))
                                            {
                                                <button type="button"
                                                        class="cod-button"
                                                        disabled="@IsCollectingCod(shipment.ShipmentId)"
                                                        @onclick="() => MarkCodCollectedAsync(shipment)">
                                                    @(IsCollectingCod(shipment.ShipmentId) ? "Đang xác nhận COD..." : "Xác nhận COD đã thu")
                                                </button>
                                            }

                                            @if (GetNextStatuses(shipment.Status).Count > 0)
                                            {
                                                <form class="operations-status-form" @onsubmit="() => UpdateStatusAsync(shipment)" @onsubmit:preventDefault="true">
                                                    <label class="sr-only" for="@($"next-status-{shipment.ShipmentId}")">Cập nhật trạng thái</label>
                                                    <select id="@($"next-status-{shipment.ShipmentId}")"
                                                            value="@GetSelectedStatusValue(shipment)"
                                                            disabled="@IsUpdating(shipment.ShipmentId)"
                                                            @onchange="eventArgs => SelectStatus(shipment.ShipmentId, eventArgs.Value?.ToString())">
                                                        @foreach (var status in GetNextStatuses(shipment.Status))
                                                        {
                                                            <option value="@status">@FormatStatus(status)</option>
                                                        }
                                                    </select>

                                                    @if (IsSelectedStatusNoteRequired(shipment))
                                                    {
                                                        <small class="field-hint danger">Bắt buộc ghi lý do giao thất bại.</small>
                                                    }

                                                    <textarea rows="2"
                                                              maxlength="500"
                                                              placeholder="Ghi chú hỗ trợ vận hành..."
                                                              @bind="StatusNotes[shipment.ShipmentId]"
                                                              @bind:event="oninput"></textarea>

                                                    <button type="submit" disabled="@IsUpdating(shipment.ShipmentId)">
                                                        @(IsUpdating(shipment.ShipmentId) ? "Đang cập nhật..." : "Cập nhật trạng thái")
                                                    </button>
                                                </form>
                                            }

                                            @if (CanManageAssignment(shipment))
                                            {
                                                <div class="assignment-management">
                                                    <div class="assignment-management-title">Điều phối lại</div>
                                                    <label class="sr-only" for="@($"reassign-shipper-{shipment.ShipmentId}")">Chọn shipper mới</label>
                                                    <select id="@($"reassign-shipper-{shipment.ShipmentId}")"
                                                            value="@GetReassignShipperValue(shipment)"
                                                            disabled="@IsAssignmentActionBusy(shipment.ShipmentId)"
                                                            @onchange="eventArgs => SelectReassignShipper(shipment, eventArgs.Value?.ToString())">
                                                        <option value="">Chọn shipper mới</option>
                                                        @foreach (var shipper in GetReassignShipperOptions(shipment))
                                                        {
                                                            <option value="@shipper.UserId">@FormatReassignShipperOption(shipment, shipper)</option>
                                                        }
                                                    </select>
                                                    @if (TryGetReassignShipper(shipment, out var reassignShipper)
                                                        && !IsShipperAreaMatch(shipment, reassignShipper.UserId))
                                                    {
                                                        <small class="field-hint danger">@reassignShipper.FullName chưa match pickup @shipment.PickupAddress.Province.</small>
                                                    }
                                                    <textarea rows="2"
                                                              maxlength="500"
                                                              placeholder="Lý do reassign..."
                                                              value="@GetReassignReason(shipment.ShipmentId)"
                                                              disabled="@IsAssignmentActionBusy(shipment.ShipmentId)"
                                                              @oninput="eventArgs => SetReassignReason(shipment.ShipmentId, eventArgs.Value?.ToString())"></textarea>
                                                    <button type="button"
                                                            class="reassign-button"
                                                            disabled="@IsAssignmentActionBusy(shipment.ShipmentId)"
                                                            @onclick="() => ReassignAsync(shipment)">
                                                        @(IsReassigning(shipment.ShipmentId) ? "Đang reassign..." : "Reassign")
                                                    </button>

                                                    <div class="assignment-management-title danger">Hủy phân công</div>
                                                    <textarea rows="2"
                                                              maxlength="500"
                                                              placeholder="Lý do hủy phân công..."
                                                              value="@GetCancelAssignmentReason(shipment.ShipmentId)"
                                                              disabled="@IsAssignmentActionBusy(shipment.ShipmentId)"
                                                              @oninput="eventArgs => SetCancelAssignmentReason(shipment.ShipmentId, eventArgs.Value?.ToString())"></textarea>
                                                    <button type="button"
                                                            class="cancel-assignment-button"
                                                            disabled="@IsAssignmentActionBusy(shipment.ShipmentId)"
                                                            @onclick="() => CancelAssignmentAsync(shipment)">
                                                        @(IsCancellingAssignment(shipment.ShipmentId) ? "Đang hủy..." : "Hủy phân công")
                                                    </button>
                                                </div>
                                            }

                                            @if (RowMessages.TryGetValue(shipment.ShipmentId, out var rowMessage))
                                            {
                                                <p class="row-message @rowMessage.Kind">@rowMessage.Text</p>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="pagination-bar">
                    <span>Trang @OperationsPageNumber.ToString("N0") / @OperationsTotalPages.ToString("N0")</span>
                    <button type="button" class="retry-button" disabled="@(OperationsPageNumber <= 1)" @onclick="PreviousOperationsPageAsync">Truoc</button>
                    <button type="button" class="retry-button" disabled="@(OperationsPageNumber >= OperationsTotalPages)" @onclick="NextOperationsPageAsync">Sau</button>
                </div>
            }
        </section>

        @if (IsAdminUser)
        {
            <section class="content-card workspace-section">
                <div class="section-heading">
                    <div>
                        <p class="eyebrow">Đối soát COD</p>
                        <h2>COD đã thu chờ đối soát</h2>
                    </div>
                    <span class="section-count">@CodSettlementCandidates.Count.ToString("N0") khoản</span>
                </div>

                @if (CodSettlementCandidates.Count == 0)
                {
                    <div class="state-card compact">
                        <span class="state-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M5 4h14v16H5V4Zm2 2v12h10V6H7Zm2 2h6v2H9V8Zm0 4h6v2H9v-2Z" />
                            </svg>
                        </span>
                        <strong>Không có COD chờ đối soát</strong>
                        <p>COD sau khi shipper hoặc vận hành xác nhận đã thu sẽ xuất hiện tại đây cho Admin chốt đối soát.</p>
                    </div>
                }
                else
                {
                    <div class="table-shell">
                        <table class="assignments-table settlement-table">
                            <thead>
                                <tr>
                                    <th>Mã vận đơn</th>
                                    <th>Người nhận</th>
                                    <th>COD</th>
                                    <th>Người thu</th>
                                    <th>Ngày thu</th>
                                    <th>Trạng thái</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cod in CodSettlementCandidates)
                                {
                                    <tr>
                                        <td><span class="tracking-code">@cod.TrackingCode</span></td>
                                        <td>
                                            <strong>@cod.ReceiverName</strong>
                                            <small>@cod.ReceiverPhone</small>
                                        </td>
                                        <td><strong>@FormatMoney(cod.CodAmount, cod.Currency)</strong></td>
                                        <td>
                                            <strong>@FormatCollectedBy(cod)</strong>
                                            @if (!string.IsNullOrWhiteSpace(cod.CollectedByEmail))
                                            {
                                                <small>@cod.CollectedByEmail</small>
                                            }
                                        </td>
                                        <td>@FormatNullableDate(cod.CollectedAtUtc)</td>
                                        <td>
                                            <small class="cod-pill @GetCodStatusClass(cod.CodStatus)">@FormatCodStatus(cod.CodStatus)</small>
                                        </td>
                                        <td>
                                            <button type="button"
                                                    class="settlement-button"
                                                    disabled="@IsSettlingCod(cod.ShipmentId)"
                                                    @onclick="() => MarkCodSettledAsync(cod)">
                                                @(IsSettlingCod(cod.ShipmentId) ? "Đang đối soát..." : "Đối soát COD")
                                            </button>
                                            @if (RowMessages.TryGetValue(cod.ShipmentId, out var rowMessage))
                                            {
                                                <p class="row-message @rowMessage.Kind">@rowMessage.Text</p>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }
    }
</div>

@code {
    private const int OperationsPageSize = 25;

    private static readonly IReadOnlyList<ShipmentStatus> OperationStatusFilterOptions =
    [
        ShipmentStatus.Assigned,
        ShipmentStatus.PickingUp,
        ShipmentStatus.PickedUp,
        ShipmentStatus.InTransit,
        ShipmentStatus.Delivering,
        ShipmentStatus.DeliveryFailed,
        ShipmentStatus.Delivered
    ];

    private bool IsLoading { get; set; } = true;

    private Guid? AssigningShipmentId { get; set; }

    private Guid? RetryingShipmentId { get; set; }

    private Guid? UpdatingShipmentId { get; set; }

    private Guid? ReassigningShipmentId { get; set; }

    private Guid? CancellingAssignmentShipmentId { get; set; }

    private Guid? CollectingCodShipmentId { get; set; }

    private Guid? SettlingCodShipmentId { get; set; }

    private bool IsBulkRetrying { get; set; }

    private string? ErrorMessage { get; set; }

    private string? SuccessMessage { get; set; }

    private string? BulkRetryMessage { get; set; }

    private bool IsAdminUser { get; set; }

    private IReadOnlyList<GetPendingPickupShipmentResponse> PendingShipments { get; set; } = [];

    private IReadOnlyList<GetOperationsShipmentResponse> OperationsShipments { get; set; } = [];

    private int PendingTotalCount { get; set; }

    private int PendingPageNumber { get; set; } = 1;

    private int PendingTotalPages { get; set; } = 1;

    private int OperationsTotalCount { get; set; }

    private int OperationsPageNumber { get; set; } = 1;

    private int OperationsTotalPages { get; set; } = 1;

    private IReadOnlyList<GetCodSettlementCandidateResponse> CodSettlementCandidates { get; set; } = [];

    private IReadOnlyList<GetActiveShipperResponse> ActiveShippers { get; set; } = [];

    private IReadOnlyDictionary<Guid, OperationsPendingAssignmentInsight> PendingAssignmentInsights { get; set; }
        = new Dictionary<Guid, OperationsPendingAssignmentInsight>();

    private Dictionary<Guid, Guid> SelectedShipperIds { get; } = [];

    private Dictionary<Guid, ShipmentStatus> SelectedStatuses { get; } = [];

    private Dictionary<Guid, Guid> ReassignShipperIds { get; } = [];

    private Dictionary<Guid, string> StatusNotes { get; } = [];

    private Dictionary<Guid, string> ReassignReasons { get; } = [];

    private Dictionary<Guid, string> CancelAssignmentReasons { get; } = [];

    private Dictionary<Guid, RowMessage> RowMessages { get; } = [];

    private HashSet<Guid> SelectedPendingShipmentIds { get; } = [];

    private string FilterSearchText { get; set; } = string.Empty;

    private string FilterProvince { get; set; } = string.Empty;

    private string FilterStatus { get; set; } = "All";

    private string FilterCodStatus { get; set; } = "All";

    private string FilterShipperIdText { get; set; } = string.Empty;

    private string FilterFromDateText { get; set; } = string.Empty;

    private string FilterToDateText { get; set; } = string.Empty;

    private string FilterMinCodText { get; set; } = string.Empty;

    private string FilterMaxCodText { get; set; } = string.Empty;

    private bool FilterSlaOnly { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(clearMessages: true);
    }

    private async Task RefreshAsync()
    {
        await LoadAsync(clearMessages: true);
    }

    private async Task ApplyFiltersAsync()
    {
        PendingPageNumber = 1;
        OperationsPageNumber = 1;
        SelectedPendingShipmentIds.Clear();
        await LoadAsync(clearMessages: true);
    }

    private async Task PreviousPendingPageAsync()
    {
        if (PendingPageNumber <= 1)
        {
            return;
        }

        PendingPageNumber--;
        await LoadAsync(clearMessages: false);
    }

    private async Task NextPendingPageAsync()
    {
        if (PendingPageNumber >= PendingTotalPages)
        {
            return;
        }

        PendingPageNumber++;
        await LoadAsync(clearMessages: false);
    }

    private async Task PreviousOperationsPageAsync()
    {
        if (OperationsPageNumber <= 1)
        {
            return;
        }

        OperationsPageNumber--;
        await LoadAsync(clearMessages: false);
    }

    private async Task NextOperationsPageAsync()
    {
        if (OperationsPageNumber >= OperationsTotalPages)
        {
            return;
        }

        OperationsPageNumber++;
        await LoadAsync(clearMessages: false);
    }

    private void TogglePendingSelection(Guid shipmentId, object? value)
    {
        var isSelected = value is bool boolValue && boolValue;
        if (isSelected)
        {
            SelectedPendingShipmentIds.Add(shipmentId);
            return;
        }

        SelectedPendingShipmentIds.Remove(shipmentId);
    }

    private void SelectVisiblePendingShipments()
    {
        foreach (var shipment in PendingShipments)
        {
            SelectedPendingShipmentIds.Add(shipment.ShipmentId);
        }
    }

    private void ClearPendingSelection()
    {
        SelectedPendingShipmentIds.Clear();
    }

    private async Task BulkRetryAutoAssignAsync()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        BulkRetryMessage = null;

        if (SelectedPendingShipmentIds.Count == 0)
        {
            BulkRetryMessage = "Chon it nhat mot don PendingPickup de bulk retry.";
            return;
        }

        var currentUserId = await GetCurrentUserIdAsync();
        if (currentUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        IsBulkRetrying = true;
        var result = await BulkRetryAutoAssignmentService.RetryAsync(new BulkRetryAutoAssignmentCommand(
            currentUserId.Value,
            SelectedPendingShipmentIds.ToList()));
        IsBulkRetrying = false;

        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            return;
        }

        SelectedPendingShipmentIds.Clear();
        BulkRetryMessage = $"Bulk retry {result.Value.RetriedCount:N0}/{result.Value.RequestedCount:N0} don; assign thanh cong {result.Value.AssignedCount:N0}, skipped {result.Value.SkippedCount:N0}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task LoadAsync(bool clearMessages)
    {
        IsLoading = true;
        ErrorMessage = null;

        if (clearMessages)
        {
            SuccessMessage = null;
            RowMessages.Clear();
            BulkRetryMessage = null;
        }

        IsAdminUser = await IsCurrentUserInRoleAsync("Admin");

        var shippersResult = await GetActiveShippersService.GetAsync();
        if (shippersResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(shippersResult.Error);
            IsLoading = false;
            return;
        }

        if (!TryBuildFilters(
            out var fromUtc,
            out var toUtc,
            out var minCodAmount,
            out var maxCodAmount,
            out var shipperId,
            out var statusFilter,
            out var codStatusFilter))
        {
            IsLoading = false;
            return;
        }

        var pendingResult = await GetPendingPickupShipmentsService.SearchAsync(new GetPendingPickupShipmentsQuery(
            NormalizeOptional(FilterSearchText),
            NormalizeOptional(FilterProvince),
            fromUtc,
            toUtc,
            minCodAmount,
            maxCodAmount,
            FilterSlaOnly,
            PendingPageNumber,
            OperationsPageSize));
        if (pendingResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(pendingResult.Error);
            IsLoading = false;
            return;
        }

        var operationsResult = await GetOperationsShipmentsService.SearchAsync(new GetOperationsShipmentsQuery(
            NormalizeOptional(FilterSearchText),
            statusFilter,
            codStatusFilter,
            shipperId,
            NormalizeOptional(FilterProvince),
            fromUtc,
            toUtc,
            minCodAmount,
            maxCodAmount,
            FilterSlaOnly,
            OperationsPageNumber,
            OperationsPageSize));
        if (operationsResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(operationsResult.Error);
            IsLoading = false;
            return;
        }

        IReadOnlyList<GetCodSettlementCandidateResponse> codSettlementCandidates = [];
        if (IsAdminUser)
        {
            var settlementResult = await GetCodSettlementCandidatesService.GetAsync();
            if (settlementResult.IsFailure)
            {
                ErrorMessage = UiDisplay.ToErrorMessage(settlementResult.Error);
                IsLoading = false;
                return;
            }

            codSettlementCandidates = settlementResult.Value;
        }

        ActiveShippers = shippersResult.Value;
        PendingShipments = pendingResult.Value.Items;
        PendingTotalCount = pendingResult.Value.TotalCount;
        PendingPageNumber = pendingResult.Value.PageNumber;
        PendingTotalPages = Math.Max(1, pendingResult.Value.TotalPages);
        OperationsShipments = operationsResult.Value.Items;
        OperationsTotalCount = operationsResult.Value.TotalCount;
        OperationsPageNumber = operationsResult.Value.PageNumber;
        OperationsTotalPages = Math.Max(1, operationsResult.Value.TotalPages);
        CodSettlementCandidates = codSettlementCandidates;
        SyncPendingAssignmentInsights();
        TrimSelectionsToCurrentShipments();
        SyncOperationState();
        IsLoading = false;
    }

    private async Task AssignAsync(GetPendingPickupShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        if (!SelectedShipperIds.TryGetValue(shipment.ShipmentId, out var shipperId))
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "Vui lòng chọn shipper active trước.");
            return;
        }

        var assignedByUserId = await GetCurrentUserIdAsync();
        if (assignedByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        AssigningShipmentId = shipment.ShipmentId;
        var isAreaMatch = IsShipperAreaMatch(shipment, shipperId);
        var assignmentNote = isAreaMatch
            ? "Điều phối assign từ operations workspace."
            : $"Manual override từ operations workspace. Shipper chưa match pickup province {shipment.PickupProvince}.";

        var result = await AssignShipperToShipmentService.AssignAsync(new AssignShipperCommand(
            shipment.ShipmentId,
            shipperId,
            assignedByUserId.Value,
            assignmentNote));

        AssigningShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        var shipperName = ActiveShippers.FirstOrDefault(shipper => shipper.UserId == shipperId)?.FullName
            ?? "shipper đã chọn";

        SuccessMessage = $"Đã assign {shipment.TrackingCode} cho {shipperName}.";
        SelectedShipperIds.Remove(shipment.ShipmentId);
        await LoadAsync(clearMessages: false);
    }

    private async Task RetryAutoAssignAsync(GetPendingPickupShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);
        RetryingShipmentId = shipment.ShipmentId;

        var currentUserId = await GetCurrentUserIdAsync();
        if (currentUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        var result = await AutoAssignShipmentService.AutoAssignAsync(
            shipment.ShipmentId,
            requestedByUserId: currentUserId.Value);

        RetryingShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        var autoAssignResult = result.Value;
        if (autoAssignResult.Status == AutoAssignShipmentStatus.Assigned)
        {
            SuccessMessage = $"Auto assign {shipment.TrackingCode} thành công.";
            SelectedShipperIds.Remove(shipment.ShipmentId);
            await LoadAsync(clearMessages: false);
            return;
        }

        var prefix = autoAssignResult.Status == AutoAssignShipmentStatus.NoEligibleShipper
            ? "Auto assign chưa tìm được shipper"
            : "Auto assign bỏ qua";
        RowMessages[shipment.ShipmentId] = new RowMessage("warning", $"{prefix}: {autoAssignResult.Reason}");
    }

    private async Task UpdateStatusAsync(GetOperationsShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        var nextStatuses = GetNextStatuses(shipment.Status);
        if (nextStatuses.Count == 0)
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "Đơn này không còn trạng thái tiếp theo.");
            return;
        }

        if (!SelectedStatuses.TryGetValue(shipment.ShipmentId, out var nextStatus)
            || !nextStatuses.Contains(nextStatus))
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "Vui lòng chọn trạng thái hợp lệ.");
            return;
        }

        if (nextStatus == ShipmentStatus.DeliveryFailed && string.IsNullOrWhiteSpace(GetNote(shipment.ShipmentId)))
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "Giao thất bại cần có ghi chú lý do.");
            return;
        }

        var changedByUserId = await GetCurrentUserIdAsync();
        if (changedByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        UpdatingShipmentId = shipment.ShipmentId;

        var result = await UpdateShipmentStatusService.UpdateAsync(new UpdateShipmentStatusCommand(
            shipment.ShipmentId,
            changedByUserId.Value,
            nextStatus,
            GetNote(shipment.ShipmentId)));

        UpdatingShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        StatusNotes[shipment.ShipmentId] = string.Empty;
        SuccessMessage = $"Đã cập nhật {shipment.TrackingCode} sang {FormatStatus(nextStatus)}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task ReassignAsync(GetOperationsShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        if (!CanManageAssignment(shipment))
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "Chỉ reassign được đơn đang ở trạng thái Assigned.");
            return;
        }

        if (!ReassignShipperIds.TryGetValue(shipment.ShipmentId, out var newShipperId))
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "Vui lòng chọn shipper mới.");
            return;
        }

        var reason = GetReassignReason(shipment.ShipmentId);
        if (string.IsNullOrWhiteSpace(reason))
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "Reassign cần có lý do.");
            return;
        }

        var reassignedByUserId = await GetCurrentUserIdAsync();
        if (reassignedByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        ReassigningShipmentId = shipment.ShipmentId;
        var result = await ReassignShipmentService.ReassignAsync(new ReassignShipmentCommand(
            shipment.ShipmentId,
            newShipperId,
            reassignedByUserId.Value,
            reason));

        ReassigningShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        var shipperName = ActiveShippers.FirstOrDefault(shipper => shipper.UserId == newShipperId)?.FullName
            ?? "shipper mới";

        ReassignReasons[shipment.ShipmentId] = string.Empty;
        SuccessMessage = $"Đã reassign {shipment.TrackingCode} cho {shipperName}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task CancelAssignmentAsync(GetOperationsShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        if (!CanManageAssignment(shipment))
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "Chỉ hủy phân công được đơn đang ở trạng thái Assigned.");
            return;
        }

        var reason = GetCancelAssignmentReason(shipment.ShipmentId);
        if (string.IsNullOrWhiteSpace(reason))
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "Hủy phân công cần có lý do.");
            return;
        }

        var cancelledByUserId = await GetCurrentUserIdAsync();
        if (cancelledByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        CancellingAssignmentShipmentId = shipment.ShipmentId;
        var result = await CancelShipmentAssignmentService.CancelAsync(new CancelShipmentAssignmentCommand(
            shipment.ShipmentId,
            cancelledByUserId.Value,
            reason));

        CancellingAssignmentShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        CancelAssignmentReasons[shipment.ShipmentId] = string.Empty;
        SuccessMessage = $"Đã hủy phân công {shipment.TrackingCode}; đơn quay về chờ phân công.";
        await LoadAsync(clearMessages: false);
    }

    private async Task MarkCodCollectedAsync(GetOperationsShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        if (!CanMarkCodCollected(shipment))
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", "COD chỉ được xác nhận khi đơn đã giao và COD đang chờ thu.");
            return;
        }

        var collectedByUserId = await GetCurrentUserIdAsync();
        if (collectedByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        CollectingCodShipmentId = shipment.ShipmentId;

        var result = await MarkCodCollectedService.MarkCollectedAsync(new MarkCodCollectedCommand(
            shipment.ShipmentId,
            collectedByUserId.Value));

        CollectingCodShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new RowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        SuccessMessage = $"Đã xác nhận thu COD cho {shipment.TrackingCode}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task MarkCodSettledAsync(GetCodSettlementCandidateResponse cod)
    {
        SuccessMessage = null;
        RowMessages.Remove(cod.ShipmentId);

        var settledByUserId = await GetCurrentUserIdAsync();
        if (settledByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        SettlingCodShipmentId = cod.ShipmentId;

        var result = await MarkCodSettledService.MarkSettledAsync(new MarkCodSettledCommand(
            cod.ShipmentId,
            settledByUserId.Value));

        SettlingCodShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[cod.ShipmentId] = new RowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        SuccessMessage = $"Đã đối soát COD cho {cod.TrackingCode}.";
        await LoadAsync(clearMessages: false);
    }

    private bool TryBuildFilters(
        out DateTimeOffset? fromUtc,
        out DateTimeOffset? toUtc,
        out decimal? minCodAmount,
        out decimal? maxCodAmount,
        out Guid? shipperId,
        out ShipmentStatus? status,
        out CodStatus? codStatus)
    {
        fromUtc = ParseStartDate(FilterFromDateText);
        toUtc = ParseEndDate(FilterToDateText);
        minCodAmount = null;
        maxCodAmount = null;
        shipperId = null;
        status = null;
        codStatus = null;

        if (fromUtc.HasValue && toUtc.HasValue && toUtc.Value < fromUtc.Value)
        {
            ErrorMessage = "Khoang ngay khong hop le.";
            return false;
        }

        if (!TryParseAmount(FilterMinCodText, out minCodAmount)
            || !TryParseAmount(FilterMaxCodText, out maxCodAmount))
        {
            return false;
        }

        if (minCodAmount.HasValue && maxCodAmount.HasValue && maxCodAmount.Value < minCodAmount.Value)
        {
            ErrorMessage = "Max COD phai lon hon hoac bang Min COD.";
            return false;
        }

        if (!string.IsNullOrWhiteSpace(FilterShipperIdText))
        {
            if (!Guid.TryParse(FilterShipperIdText.Trim(), out var parsedShipperId))
            {
                ErrorMessage = "Shipper id filter khong hop le.";
                return false;
            }

            shipperId = parsedShipperId;
        }

        if (FilterStatus != "All" && Enum.TryParse<ShipmentStatus>(FilterStatus, out var parsedStatus))
        {
            status = parsedStatus;
        }

        if (FilterCodStatus != "All" && Enum.TryParse<CodStatus>(FilterCodStatus, out var parsedCodStatus))
        {
            codStatus = parsedCodStatus;
        }

        return true;
    }

    private static DateTimeOffset? ParseStartDate(string value)
    {
        return DateOnly.TryParse(value, out var date)
            ? date.ToDateTime(TimeOnly.MinValue, DateTimeKind.Local).ToUniversalTime()
            : null;
    }

    private static DateTimeOffset? ParseEndDate(string value)
    {
        return DateOnly.TryParse(value, out var date)
            ? date.ToDateTime(TimeOnly.MaxValue, DateTimeKind.Local).ToUniversalTime()
            : null;
    }

    private bool TryParseAmount(string value, out decimal? amount)
    {
        amount = null;
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (decimal.TryParse(value.Trim(), out var parsed))
        {
            amount = parsed;
            return true;
        }

        ErrorMessage = "COD amount filter khong hop le.";
        return false;
    }

    private static string? NormalizeOptional(string value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? null
            : value.Trim();
    }

    private void OnFilterFromChanged(ChangeEventArgs args)
    {
        FilterFromDateText = args.Value?.ToString() ?? string.Empty;
    }

    private void OnFilterToChanged(ChangeEventArgs args)
    {
        FilterToDateText = args.Value?.ToString() ?? string.Empty;
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userIdValue = authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        return Guid.TryParse(userIdValue, out var userId)
            ? userId
            : null;
    }

