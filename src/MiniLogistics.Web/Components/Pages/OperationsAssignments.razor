        await LoadAsync(clearMessages: false);
    }

    private bool TryBuildFilters(
        out DateTimeOffset? fromUtc,
        out DateTimeOffset? toUtc,
        out decimal? minCodAmount,
        out decimal? maxCodAmount,
        out Guid? shipperId,
        out ShipmentStatus? status,
        out CodStatus? codStatus)
    {
        fromUtc = ParseStartDate(FilterFromDateText);
        toUtc = ParseEndDate(FilterToDateText);
        minCodAmount = null;
        maxCodAmount = null;
        shipperId = null;
        status = null;
        codStatus = null;

        if (fromUtc.HasValue && toUtc.HasValue && toUtc.Value < fromUtc.Value)
        {
            ErrorMessage = "Khoang ngay khong hop le.";
            return false;
        }

        if (!TryParseAmount(FilterMinCodText, out minCodAmount)
            || !TryParseAmount(FilterMaxCodText, out maxCodAmount))
        {
            return false;
        }

        if (minCodAmount.HasValue && maxCodAmount.HasValue && maxCodAmount.Value < minCodAmount.Value)
        {
            ErrorMessage = "Max COD phai lon hon hoac bang Min COD.";
            return false;
        }

        if (!string.IsNullOrWhiteSpace(FilterShipperIdText))
        {
            if (!Guid.TryParse(FilterShipperIdText.Trim(), out var parsedShipperId))
            {
                ErrorMessage = "Shipper id filter khong hop le.";
                return false;
            }

            shipperId = parsedShipperId;
        }

        if (FilterStatus != "All" && Enum.TryParse<ShipmentStatus>(FilterStatus, out var parsedStatus))
        {
            status = parsedStatus;
        }

        if (FilterCodStatus != "All" && Enum.TryParse<CodStatus>(FilterCodStatus, out var parsedCodStatus))
        {
            codStatus = parsedCodStatus;
        }

        return true;
    }

    private static DateTimeOffset? ParseStartDate(string value)
    {
        return DateOnly.TryParse(value, out var date)
            ? date.ToDateTime(TimeOnly.MinValue, DateTimeKind.Local).ToUniversalTime()
            : null;
    }

    private static DateTimeOffset? ParseEndDate(string value)
    {
        return DateOnly.TryParse(value, out var date)
            ? date.ToDateTime(TimeOnly.MaxValue, DateTimeKind.Local).ToUniversalTime()
            : null;
    }

    private bool TryParseAmount(string value, out decimal? amount)
    {
        amount = null;
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (decimal.TryParse(value.Trim(), out var parsed))
        {
            amount = parsed;
            return true;
        }

        ErrorMessage = "COD amount filter khong hop le.";
        return false;
    }

    private static string? NormalizeOptional(string value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? null
            : value.Trim();
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userIdValue = authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        return Guid.TryParse(userIdValue, out var userId)
            ? userId
            : null;
    }

    private async Task<bool> IsCurrentUserInRoleAsync(string role)
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        return authenticationState.User.IsInRole(role);
    }

    private void SelectShipper(PendingShipperSelectionChanged change)
    {
        var shipment = change.Shipment;
        RowMessages.Remove(shipment.ShipmentId);

        if (Guid.TryParse(change.Value, out var shipperId))
        {
            SelectedShipperIds[shipment.ShipmentId] = shipperId;

            if (!IsShipperAreaMatch(shipment, shipperId))
            {
                var shipperName = ActiveShippers.FirstOrDefault(shipper => shipper.UserId == shipperId)?.FullName
                    ?? "Shipper đã chọn";

                RowMessages[shipment.ShipmentId] = new OperationsRowMessage(
                    "warning",
                    $"{shipperName} chưa match pickup {shipment.PickupProvince}. Manual override vẫn được phép.");
            }

            return;
        }

        SelectedShipperIds.Remove(shipment.ShipmentId);
    }

    private void SelectStatus(ShipmentStatusSelectionChanged change)
    {
        var shipmentId = change.ShipmentId;
        RowMessages.Remove(shipmentId);

        if (Enum.TryParse<ShipmentStatus>(change.Value, out var status))
        {
            SelectedStatuses[shipmentId] = status;
        }
    }

    private void SelectReassignShipper(ReassignShipperSelectionChanged change)
    {
        var shipment = change.Shipment;
        RowMessages.Remove(shipment.ShipmentId);

        if (Guid.TryParse(change.Value, out var shipperId))
        {
            ReassignShipperIds[shipment.ShipmentId] = shipperId;

            if (!IsShipperAreaMatch(shipment, shipperId))
            {
                var shipperName = ActiveShippers.FirstOrDefault(shipper => shipper.UserId == shipperId)?.FullName
                    ?? "Shipper đã chọn";

                RowMessages[shipment.ShipmentId] = new OperationsRowMessage(
                    "warning",
                    $"{shipperName} chưa match pickup {shipment.PickupAddress.Province}. Reassign vẫn được phép với lý do rõ ràng.");
            }

            return;
        }

        ReassignShipperIds.Remove(shipment.ShipmentId);
    }

