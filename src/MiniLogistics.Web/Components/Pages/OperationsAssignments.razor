@page "/operations/assignments"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Operator")]
@using System.Security.Claims
@using MiniLogistics.Application.CashOnDelivery.GetCodSettlementCandidates
@using MiniLogistics.Application.CashOnDelivery.MarkCodCollected
@using MiniLogistics.Application.CashOnDelivery.MarkCodSettled
@using MiniLogistics.Application.Shipments
@using MiniLogistics.Application.Shipments.AssignShipperToShipment
@using MiniLogistics.Application.Shipments.AutoAssignShipment
@using MiniLogistics.Application.Shipments.BulkRetryAutoAssignment
@using MiniLogistics.Application.Shipments.CancelShipmentAssignment
@using MiniLogistics.Application.Shipments.GetOperationsShipments
@using MiniLogistics.Application.Shipments.GetPendingPickupShipments
@using MiniLogistics.Application.Shipments.ReassignShipment
@using MiniLogistics.Application.Shipments.UpdateShipmentStatus
@using MiniLogistics.Application.Shippers.GetActiveShippers
@using MiniLogistics.Domain.CashOnDelivery
@using MiniLogistics.Domain.Shipments
@using MiniLogistics.Web.Components.Pages.Operations
@inject IAssignShipperToShipmentService AssignShipperToShipmentService
@inject IAutoAssignShipmentService AutoAssignShipmentService
@inject IBulkRetryAutoAssignmentService BulkRetryAutoAssignmentService
@inject ICancelShipmentAssignmentService CancelShipmentAssignmentService
@inject IGetCodSettlementCandidatesService GetCodSettlementCandidatesService
@inject IGetActiveShippersService GetActiveShippersService
@inject IGetOperationsShipmentsService GetOperationsShipmentsService
@inject IGetPendingPickupShipmentsService GetPendingPickupShipmentsService
@inject IMarkCodCollectedService MarkCodCollectedService
@inject IMarkCodSettledService MarkCodSettledService
@inject IReassignShipmentService ReassignShipmentService
@inject IUpdateShipmentStatusService UpdateShipmentStatusService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Điều phối vận hành - MiniLogistics</PageTitle>

<div class="operations-assignments-page">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Vận hành</p>
            <h1>Điều phối vận hành</h1>
            <p>Phân công shipper, theo dõi đơn đang xử lý và hỗ trợ cập nhật trạng thái hoặc COD khi cần.</p>
        </div>

        <button type="button" class="refresh-button" disabled="@IsLoading" @onclick="RefreshAsync">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 5a7 7 0 1 1-6.3 4H3.5A9 9 0 1 0 6 5.8V3H4v6h6V7H7.4A7 7 0 0 1 12 5Z" />
            </svg>
            <span>Làm mới</span>
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert-box danger" role="alert">@ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <div class="alert-box success" role="status">@SuccessMessage</div>
    }

    @if (IsLoading)
    {
        <section class="content-card state-card" aria-live="polite">
            <span class="state-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2a10 10 0 1 0 10 10h-2a8 8 0 1 1-8-8V2Z" />
                </svg>
            </span>
            <strong>Đang tải workspace điều phối</strong>
        </section>
    }
    else
    {
        <section class="content-card">
            <div class="summary-strip" aria-label="Tóm tắt điều phối">
                <article>
                    <span>Chờ phân công</span>
                    <strong>@PendingTotalCount.ToString("N0")</strong>
                </article>
                <article>
                    <span>Đang vận hành</span>
                    <strong>@OperationsTotalCount.ToString("N0")</strong>
                </article>
                <article>
                    <span>Shipper active</span>
                    <strong>@ActiveShippers.Count.ToString("N0")</strong>
                </article>
                <article>
                    <span>COD cần hỗ trợ</span>
                    <strong>@OperationsShipments.Count(OperationsDisplay.CanMarkCodCollected).ToString("N0")</strong>
                </article>
                @if (IsAdminUser)
                {
                    <article>
                        <span>COD chờ đối soát</span>
                        <strong>@CodSettlementCandidates.Count.ToString("N0")</strong>
                    </article>
                }
            </div>
        </section>

        <OperationsFilterBar IsLoading="IsLoading"
                             StatusOptions="OperationStatusFilterOptions"
                             SearchText="FilterSearchText"
                             SearchTextChanged="value => FilterSearchText = value"
                             Province="FilterProvince"
                             ProvinceChanged="value => FilterProvince = value"
                             Status="FilterStatus"
                             StatusChanged="value => FilterStatus = value"
                             CodStatus="FilterCodStatus"
                             CodStatusChanged="value => FilterCodStatus = value"
                             ShipperIdText="FilterShipperIdText"
                             ShipperIdTextChanged="value => FilterShipperIdText = value"
                             FromDateText="FilterFromDateText"
                             FromDateTextChanged="value => FilterFromDateText = value"
                             ToDateText="FilterToDateText"
                             ToDateTextChanged="value => FilterToDateText = value"
                             MinCodText="FilterMinCodText"
                             MinCodTextChanged="value => FilterMinCodText = value"
                             MaxCodText="FilterMaxCodText"
                             MaxCodTextChanged="value => FilterMaxCodText = value"
                             SlaOnly="FilterSlaOnly"
                             SlaOnlyChanged="value => FilterSlaOnly = value"
                             ApplyFilters="ApplyFiltersAsync" />

        <PendingPickupList Shipments="PendingShipments"
                           ActiveShippers="ActiveShippers"
                           PendingAssignmentInsights="PendingAssignmentInsights"
                           SelectedShipperIds="SelectedShipperIds"
                           SelectedShipmentIds="SelectedPendingShipmentIds"
                           RowMessages="RowMessages"
                           TotalCount="PendingTotalCount"
                           PageNumber="PendingPageNumber"
                           TotalPages="PendingTotalPages"
                           IsBulkRetrying="IsBulkRetrying"
                           BulkRetryMessage="BulkRetryMessage"
                           AssigningShipmentId="AssigningShipmentId"
                           RetryingShipmentId="RetryingShipmentId"
                           ActiveShipmentCountResolver="GetActiveShipmentCount"
                           SelectVisible="SelectVisiblePendingShipments"
                           ClearSelection="ClearPendingSelection"
                           BulkRetry="BulkRetryAutoAssignAsync"
                           SelectShipper="SelectShipper"
                           ToggleSelection="TogglePendingSelection"
                           RetryAutoAssign="RetryAutoAssignAsync"
                           AssignShipment="AssignAsync"
                           PreviousPage="PreviousPendingPageAsync"
                           NextPage="NextPendingPageAsync" />

        <OperationsShipmentList Shipments="OperationsShipments"
                                ActiveShippers="ActiveShippers"
                                SelectedStatuses="SelectedStatuses"
                                StatusNotes="StatusNotes"
                                ReassignShipperIds="ReassignShipperIds"
                                ReassignReasons="ReassignReasons"
                                CancelAssignmentReasons="CancelAssignmentReasons"
                                RowMessages="RowMessages"
                                UpdatingShipmentId="UpdatingShipmentId"
                                ReassigningShipmentId="ReassigningShipmentId"
                                CancellingAssignmentShipmentId="CancellingAssignmentShipmentId"
                                CollectingCodShipmentId="CollectingCodShipmentId"
                                PageNumber="OperationsPageNumber"
                                TotalPages="OperationsTotalPages"
                                ActiveShipmentCountResolver="GetActiveShipmentCount"
                                MarkCodCollected="MarkCodCollectedAsync"
                                UpdateStatus="UpdateStatusAsync"
                                SelectStatus="SelectStatus"
                                StatusNoteChanged="SetStatusNote"
                                SelectReassignShipper="SelectReassignShipper"
                                ReassignReasonChanged="SetReassignReason"
                                ReassignShipment="ReassignAsync"
                                CancelReasonChanged="SetCancelAssignmentReason"
                                CancelAssignment="CancelAssignmentAsync"
                                PreviousPage="PreviousOperationsPageAsync"
                                NextPage="NextOperationsPageAsync" />

        @if (IsAdminUser)
        {
            <CodSettlementList Candidates="CodSettlementCandidates"
                               RowMessages="RowMessages"
                               SettlingCodShipmentId="SettlingCodShipmentId"
                               MarkCodSettled="MarkCodSettledAsync" />
        }
    }
</div>

@code {
    private const int OperationsPageSize = 25;

    private static readonly IReadOnlyList<ShipmentStatus> OperationStatusFilterOptions =
    [
        ShipmentStatus.Assigned,
        ShipmentStatus.PickingUp,
        ShipmentStatus.PickedUp,
        ShipmentStatus.InTransit,
        ShipmentStatus.Delivering,
        ShipmentStatus.DeliveryFailed,
        ShipmentStatus.Delivered
    ];

    private bool IsLoading { get; set; } = true;

    private Guid? AssigningShipmentId { get; set; }

    private Guid? RetryingShipmentId { get; set; }

    private Guid? UpdatingShipmentId { get; set; }

    private Guid? ReassigningShipmentId { get; set; }

    private Guid? CancellingAssignmentShipmentId { get; set; }

    private Guid? CollectingCodShipmentId { get; set; }

    private Guid? SettlingCodShipmentId { get; set; }

    private bool IsBulkRetrying { get; set; }

    private string? ErrorMessage { get; set; }

    private string? SuccessMessage { get; set; }

    private string? BulkRetryMessage { get; set; }

    private bool IsAdminUser { get; set; }

    private IReadOnlyList<GetPendingPickupShipmentResponse> PendingShipments { get; set; } = [];

    private IReadOnlyList<GetOperationsShipmentResponse> OperationsShipments { get; set; } = [];

    private int PendingTotalCount { get; set; }

    private int PendingPageNumber { get; set; } = 1;

    private int PendingTotalPages { get; set; } = 1;

    private int OperationsTotalCount { get; set; }

    private int OperationsPageNumber { get; set; } = 1;

    private int OperationsTotalPages { get; set; } = 1;

    private IReadOnlyList<GetCodSettlementCandidateResponse> CodSettlementCandidates { get; set; } = [];

    private IReadOnlyList<GetActiveShipperResponse> ActiveShippers { get; set; } = [];

    private IReadOnlyDictionary<Guid, OperationsPendingAssignmentInsight> PendingAssignmentInsights { get; set; }
        = new Dictionary<Guid, OperationsPendingAssignmentInsight>();

    private Dictionary<Guid, Guid> SelectedShipperIds { get; } = [];

    private Dictionary<Guid, ShipmentStatus> SelectedStatuses { get; } = [];

    private Dictionary<Guid, Guid> ReassignShipperIds { get; } = [];

    private Dictionary<Guid, string> StatusNotes { get; } = [];

    private Dictionary<Guid, string> ReassignReasons { get; } = [];

    private Dictionary<Guid, string> CancelAssignmentReasons { get; } = [];

    private Dictionary<Guid, OperationsRowMessage> RowMessages { get; } = [];

    private HashSet<Guid> SelectedPendingShipmentIds { get; } = [];

    private string FilterSearchText { get; set; } = string.Empty;

    private string FilterProvince { get; set; } = string.Empty;

    private string FilterStatus { get; set; } = "All";

    private string FilterCodStatus { get; set; } = "All";

    private string FilterShipperIdText { get; set; } = string.Empty;

    private string FilterFromDateText { get; set; } = string.Empty;

    private string FilterToDateText { get; set; } = string.Empty;

    private string FilterMinCodText { get; set; } = string.Empty;

    private string FilterMaxCodText { get; set; } = string.Empty;

    private bool FilterSlaOnly { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(clearMessages: true);
    }

    private async Task RefreshAsync()
    {
        await LoadAsync(clearMessages: true);
    }

    private async Task ApplyFiltersAsync()
    {
        PendingPageNumber = 1;
        OperationsPageNumber = 1;
        SelectedPendingShipmentIds.Clear();
        await LoadAsync(clearMessages: true);
    }

    private async Task PreviousPendingPageAsync()
    {
        if (PendingPageNumber <= 1)
        {
            return;
        }

        PendingPageNumber--;
        await LoadAsync(clearMessages: false);
    }

    private async Task NextPendingPageAsync()
    {
        if (PendingPageNumber >= PendingTotalPages)
        {
            return;
        }

        PendingPageNumber++;
        await LoadAsync(clearMessages: false);
    }

    private async Task PreviousOperationsPageAsync()
    {
        if (OperationsPageNumber <= 1)
        {
            return;
        }

        OperationsPageNumber--;
        await LoadAsync(clearMessages: false);
    }

    private async Task NextOperationsPageAsync()
    {
        if (OperationsPageNumber >= OperationsTotalPages)
        {
            return;
        }

        OperationsPageNumber++;
        await LoadAsync(clearMessages: false);
    }

    private void TogglePendingSelection(PendingShipmentSelectionChanged change)
    {
        if (change.IsSelected)
        {
            SelectedPendingShipmentIds.Add(change.ShipmentId);
            return;
        }

        SelectedPendingShipmentIds.Remove(change.ShipmentId);
    }

    private void SelectVisiblePendingShipments()
    {
        foreach (var shipment in PendingShipments)
        {
            SelectedPendingShipmentIds.Add(shipment.ShipmentId);
        }
    }

    private void ClearPendingSelection()
    {
        SelectedPendingShipmentIds.Clear();
    }

    private async Task BulkRetryAutoAssignAsync()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        BulkRetryMessage = null;

        if (SelectedPendingShipmentIds.Count == 0)
        {
            BulkRetryMessage = "Chon it nhat mot don PendingPickup de bulk retry.";
            return;
        }

        var currentUserId = await GetCurrentUserIdAsync();
        if (currentUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        IsBulkRetrying = true;
        var result = await BulkRetryAutoAssignmentService.RetryAsync(new BulkRetryAutoAssignmentCommand(
            currentUserId.Value,
            SelectedPendingShipmentIds.ToList()));
        IsBulkRetrying = false;

        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            return;
        }

        SelectedPendingShipmentIds.Clear();
        BulkRetryMessage = $"Bulk retry {result.Value.RetriedCount:N0}/{result.Value.RequestedCount:N0} don; assign thanh cong {result.Value.AssignedCount:N0}, skipped {result.Value.SkippedCount:N0}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task LoadAsync(bool clearMessages)
    {
        IsLoading = true;
        ErrorMessage = null;

        if (clearMessages)
        {
            SuccessMessage = null;
            RowMessages.Clear();
            BulkRetryMessage = null;
        }

        IsAdminUser = await IsCurrentUserInRoleAsync("Admin");

        var shippersResult = await GetActiveShippersService.GetAsync();
        if (shippersResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(shippersResult.Error);
            IsLoading = false;
            return;
        }

        if (!TryBuildFilters(
            out var fromUtc,
            out var toUtc,
            out var minCodAmount,
            out var maxCodAmount,
            out var shipperId,
            out var statusFilter,
            out var codStatusFilter))
        {
            IsLoading = false;
            return;
        }

        var pendingResult = await GetPendingPickupShipmentsService.SearchAsync(new GetPendingPickupShipmentsQuery(
            NormalizeOptional(FilterSearchText),
            NormalizeOptional(FilterProvince),
            fromUtc,
            toUtc,
            minCodAmount,
            maxCodAmount,
            FilterSlaOnly,
            PendingPageNumber,
            OperationsPageSize));
        if (pendingResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(pendingResult.Error);
            IsLoading = false;
            return;
        }

        var operationsResult = await GetOperationsShipmentsService.SearchAsync(new GetOperationsShipmentsQuery(
            NormalizeOptional(FilterSearchText),
            statusFilter,
            codStatusFilter,
            shipperId,
            NormalizeOptional(FilterProvince),
            fromUtc,
            toUtc,
            minCodAmount,
            maxCodAmount,
            FilterSlaOnly,
            OperationsPageNumber,
            OperationsPageSize));
        if (operationsResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(operationsResult.Error);
            IsLoading = false;
            return;
        }

        IReadOnlyList<GetCodSettlementCandidateResponse> codSettlementCandidates = [];
        if (IsAdminUser)
        {
            var settlementResult = await GetCodSettlementCandidatesService.GetAsync();
            if (settlementResult.IsFailure)
            {
                ErrorMessage = UiDisplay.ToErrorMessage(settlementResult.Error);
                IsLoading = false;
                return;
            }

            codSettlementCandidates = settlementResult.Value;
        }

        ActiveShippers = shippersResult.Value;
        PendingShipments = pendingResult.Value.Items;
        PendingTotalCount = pendingResult.Value.TotalCount;
        PendingPageNumber = pendingResult.Value.PageNumber;
        PendingTotalPages = Math.Max(1, pendingResult.Value.TotalPages);
        OperationsShipments = operationsResult.Value.Items;
        OperationsTotalCount = operationsResult.Value.TotalCount;
        OperationsPageNumber = operationsResult.Value.PageNumber;
        OperationsTotalPages = Math.Max(1, operationsResult.Value.TotalPages);
        CodSettlementCandidates = codSettlementCandidates;
        SyncPendingAssignmentInsights();
        TrimSelectionsToCurrentShipments();
        SyncOperationState();
        IsLoading = false;
    }

    private async Task AssignAsync(GetPendingPickupShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        if (!SelectedShipperIds.TryGetValue(shipment.ShipmentId, out var shipperId))
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "Vui lòng chọn shipper active trước.");
            return;
        }

        var assignedByUserId = await GetCurrentUserIdAsync();
        if (assignedByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        AssigningShipmentId = shipment.ShipmentId;
        var isAreaMatch = IsShipperAreaMatch(shipment, shipperId);
        var assignmentNote = isAreaMatch
            ? "Điều phối assign từ operations workspace."
            : $"Manual override từ operations workspace. Shipper chưa match pickup province {shipment.PickupProvince}.";

        var result = await AssignShipperToShipmentService.AssignAsync(new AssignShipperCommand(
            shipment.ShipmentId,
            shipperId,
            assignedByUserId.Value,
            assignmentNote));

        AssigningShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        var shipperName = ActiveShippers.FirstOrDefault(shipper => shipper.UserId == shipperId)?.FullName
            ?? "shipper đã chọn";

        SuccessMessage = $"Đã assign {shipment.TrackingCode} cho {shipperName}.";
        SelectedShipperIds.Remove(shipment.ShipmentId);
        await LoadAsync(clearMessages: false);
    }

    private async Task RetryAutoAssignAsync(GetPendingPickupShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);
        RetryingShipmentId = shipment.ShipmentId;

        var currentUserId = await GetCurrentUserIdAsync();
        if (currentUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        var result = await AutoAssignShipmentService.AutoAssignAsync(
            shipment.ShipmentId,
            requestedByUserId: currentUserId.Value);

        RetryingShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        var autoAssignResult = result.Value;
        if (autoAssignResult.Status == AutoAssignShipmentStatus.Assigned)
        {
            SuccessMessage = $"Auto assign {shipment.TrackingCode} thành công.";
            SelectedShipperIds.Remove(shipment.ShipmentId);
            await LoadAsync(clearMessages: false);
            return;
        }

        var prefix = autoAssignResult.Status == AutoAssignShipmentStatus.NoEligibleShipper
            ? "Auto assign chưa tìm được shipper"
            : "Auto assign bỏ qua";
        RowMessages[shipment.ShipmentId] = new OperationsRowMessage("warning", $"{prefix}: {autoAssignResult.Reason}");
    }

    private async Task UpdateStatusAsync(GetOperationsShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        var nextStatuses = OperationsDisplay.GetNextStatuses(shipment.Status);
        if (nextStatuses.Count == 0)
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "Đơn này không còn trạng thái tiếp theo.");
            return;
        }

        if (!SelectedStatuses.TryGetValue(shipment.ShipmentId, out var nextStatus)
            || !nextStatuses.Contains(nextStatus))
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "Vui lòng chọn trạng thái hợp lệ.");
            return;
        }

        if (nextStatus == ShipmentStatus.DeliveryFailed && string.IsNullOrWhiteSpace(GetNote(shipment.ShipmentId)))
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "Giao thất bại cần có ghi chú lý do.");
            return;
        }

        var changedByUserId = await GetCurrentUserIdAsync();
        if (changedByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        UpdatingShipmentId = shipment.ShipmentId;

        var result = await UpdateShipmentStatusService.UpdateAsync(new UpdateShipmentStatusCommand(
            shipment.ShipmentId,
            changedByUserId.Value,
            nextStatus,
            GetNote(shipment.ShipmentId)));

        UpdatingShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        StatusNotes[shipment.ShipmentId] = string.Empty;
        SuccessMessage = $"Đã cập nhật {shipment.TrackingCode} sang {OperationsDisplay.FormatStatus(nextStatus)}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task ReassignAsync(GetOperationsShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        if (!OperationsDisplay.CanManageAssignment(shipment))
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "Chỉ reassign được đơn đang ở trạng thái Assigned.");
            return;
        }

        if (!ReassignShipperIds.TryGetValue(shipment.ShipmentId, out var newShipperId))
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "Vui lòng chọn shipper mới.");
            return;
        }

        var reason = GetReassignReason(shipment.ShipmentId);
        if (string.IsNullOrWhiteSpace(reason))
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "Reassign cần có lý do.");
            return;
        }

        var reassignedByUserId = await GetCurrentUserIdAsync();
        if (reassignedByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        ReassigningShipmentId = shipment.ShipmentId;
        var result = await ReassignShipmentService.ReassignAsync(new ReassignShipmentCommand(
            shipment.ShipmentId,
            newShipperId,
            reassignedByUserId.Value,
            reason));

        ReassigningShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        var shipperName = ActiveShippers.FirstOrDefault(shipper => shipper.UserId == newShipperId)?.FullName
            ?? "shipper mới";

        ReassignReasons[shipment.ShipmentId] = string.Empty;
        SuccessMessage = $"Đã reassign {shipment.TrackingCode} cho {shipperName}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task CancelAssignmentAsync(GetOperationsShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        if (!OperationsDisplay.CanManageAssignment(shipment))
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "Chỉ hủy phân công được đơn đang ở trạng thái Assigned.");
            return;
        }

        var reason = GetCancelAssignmentReason(shipment.ShipmentId);
        if (string.IsNullOrWhiteSpace(reason))
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "Hủy phân công cần có lý do.");
            return;
        }

        var cancelledByUserId = await GetCurrentUserIdAsync();
        if (cancelledByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        CancellingAssignmentShipmentId = shipment.ShipmentId;
        var result = await CancelShipmentAssignmentService.CancelAsync(new CancelShipmentAssignmentCommand(
            shipment.ShipmentId,
            cancelledByUserId.Value,
            reason));

        CancellingAssignmentShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        CancelAssignmentReasons[shipment.ShipmentId] = string.Empty;
        SuccessMessage = $"Đã hủy phân công {shipment.TrackingCode}; đơn quay về chờ phân công.";
        await LoadAsync(clearMessages: false);
    }

    private async Task MarkCodCollectedAsync(GetOperationsShipmentResponse shipment)
    {
        SuccessMessage = null;
        RowMessages.Remove(shipment.ShipmentId);

        if (!OperationsDisplay.CanMarkCodCollected(shipment))
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", "COD chỉ được xác nhận khi đơn đã giao và COD đang chờ thu.");
            return;
        }

        var collectedByUserId = await GetCurrentUserIdAsync();
        if (collectedByUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        CollectingCodShipmentId = shipment.ShipmentId;

        var result = await MarkCodCollectedService.MarkCollectedAsync(new MarkCodCollectedCommand(
            shipment.ShipmentId,
            collectedByUserId.Value));

        CollectingCodShipmentId = null;

        if (result.IsFailure)
        {
            RowMessages[shipment.ShipmentId] = new OperationsRowMessage("danger", UiDisplay.ToErrorMessage(result.Error));
            return;
        }

        SuccessMessage = $"Đã xác nhận thu COD cho {shipment.TrackingCode}.";
        await LoadAsync(clearMessages: false);
    }

    private async Task MarkCodSettledAsync(GetCodSettlementCandidateResponse cod)
    {
        SuccessMessage = null;
        RowMessages.Remove(cod.ShipmentId);

        var settledByUserId = await GetCurrentUserIdAsync();
        if (settledByUserId is null)
