    private void TrimSelectionsToCurrentShipments()
    {
        var pendingShipmentIds = PendingShipments.Select(shipment => shipment.ShipmentId).ToHashSet();
        foreach (var shipmentId in SelectedShipperIds.Keys.ToList())
        {
            if (!pendingShipmentIds.Contains(shipmentId))
            {
                SelectedShipperIds.Remove(shipmentId);
            }
        }

        foreach (var shipmentId in SelectedPendingShipmentIds.ToList())
        {
            if (!pendingShipmentIds.Contains(shipmentId))
            {
                SelectedPendingShipmentIds.Remove(shipmentId);
            }
        }

        var operationsShipmentIds = OperationsShipments.Select(shipment => shipment.ShipmentId).ToHashSet();
        foreach (var shipmentId in SelectedStatuses.Keys.ToList())
        {
            if (!operationsShipmentIds.Contains(shipmentId))
            {
                SelectedStatuses.Remove(shipmentId);
            }
        }

        foreach (var shipmentId in ReassignShipperIds.Keys.ToList())
        {
            if (!operationsShipmentIds.Contains(shipmentId))
            {
                ReassignShipperIds.Remove(shipmentId);
            }
        }

        foreach (var shipmentId in StatusNotes.Keys.ToList())
        {
            if (!operationsShipmentIds.Contains(shipmentId))
            {
                StatusNotes.Remove(shipmentId);
            }
        }

        foreach (var shipmentId in ReassignReasons.Keys.ToList())
        {
            if (!operationsShipmentIds.Contains(shipmentId))
            {
                ReassignReasons.Remove(shipmentId);
            }
        }

        foreach (var shipmentId in CancelAssignmentReasons.Keys.ToList())
        {
            if (!operationsShipmentIds.Contains(shipmentId))
            {
                CancelAssignmentReasons.Remove(shipmentId);
            }
        }

        var settlementShipmentIds = CodSettlementCandidates.Select(candidate => candidate.ShipmentId).ToHashSet();
        foreach (var shipmentId in RowMessages.Keys.ToList())
        {
            if (!pendingShipmentIds.Contains(shipmentId)
                && !operationsShipmentIds.Contains(shipmentId)
                && !settlementShipmentIds.Contains(shipmentId))
            {
                RowMessages.Remove(shipmentId);
            }
        }
    }

    private void SyncPendingAssignmentInsights()
    {
