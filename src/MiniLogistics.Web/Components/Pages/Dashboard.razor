@page "/dashboard"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Shop")]
@using System.Security.Claims
@using MiniLogistics.Application.Shops.GetCurrentShop
@using MiniLogistics.Application.Shipments.GetShipmentsForCurrentShop
@using MiniLogistics.Domain.Shipments
@inject IGetCurrentShopService GetCurrentShopService
@inject IGetShipmentsForCurrentShopService GetShipmentsForCurrentShopService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Shop Dashboard - MiniLogistics</PageTitle>

<div class="dashboard-page">
    <section class="dashboard-heading">
        <div>
            <h1>Chào mừng trở lại, @ShopDisplayName!</h1>
            <p>Dưới đây là tổng quan hoạt động vận chuyển từ dữ liệu đơn hàng hiện có.</p>
        </div>

        <div class="heading-actions">
            <a class="primary-action" href="/shipments/create">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M11 5h2v6h6v2h-6v6h-2v-6H5v-2h6V5Z" /></svg>
                <span>Tạo đơn mới</span>
            </a>
            <a class="secondary-action" href="/tracking">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10.5 4a6.5 6.5 0 0 1 5.1 10.5l4 4-1.4 1.4-4-4A6.5 6.5 0 1 1 10.5 4Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" /></svg>
                <span>Tra cứu đơn hàng</span>
            </a>
            <a class="secondary-action" href="/shipments">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M11 4h2v9.2l3.6-3.6L18 11l-6 6-6-6 1.4-1.4 3.6 3.6V4ZM5 19h14v2H5v-2Z" /></svg>
                <span>Danh sách đơn</span>
            </a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="dashboard-alert" role="alert">@ErrorMessage</div>
    }

    @if (IsLoading)
    {
        <section class="dashboard-card state-card" aria-live="polite">
            <span class="empty-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 1 0 10 10h-2a8 8 0 1 1-8-8V2Z" /></svg>
            </span>
            <strong>Đang tải dữ liệu dashboard</strong>
        </section>
    }
    else
    {
        <section class="stats-grid" aria-label="Shop statistics">
            @foreach (var card in StatisticCards)
            {
                <article class="stat-card">
                    <span class="stat-icon @card.IconClass">
                        @((MarkupString)card.Icon)
                    </span>
                    <div>
                        <p>@card.Label</p>
                        <strong>@card.Value</strong>
                    </div>
                    <small class="stat-note">@card.Note</small>
                </article>
            }
        </section>

        <section class="dashboard-card latest-orders">
            <div class="card-header">
                <h2>Đơn hàng mới nhất</h2>
                <a class="card-link" href="/shipments">Xem tất cả</a>
            </div>

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Mã vận đơn</th>
                            <th>Người nhận</th>
                            <th>Tuyến</th>
                            <th>Cân tính phí</th>
                            <th>Trạng thái</th>
                            <th>COD</th>
                            <th>Phí vận chuyển</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (LatestShipments.Count == 0)
                        {
                            <tr>
                                <td colspan="9">
                                    <div class="empty-state">
                                        <span>
                                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Zm2 1.2v6.6l5 2.8v-6.6L6 8.7Zm7 9.4 5-2.8V8.7l-5 2.8v6.6Zm-6-11L12 10l5-2.9-5-2.8-5 2.8Z" /></svg>
                                        </span>
                                        <strong>Chưa có đơn hàng để hiển thị</strong>
                                        <p>Tạo vận đơn đầu tiên để dashboard tự động cập nhật số liệu.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var shipment in LatestShipments)
                            {
                                <tr>
                                    <td>
                                        <a class="tracking-link" href="@($"/shipments/{shipment.ShipmentId}")">
                                            @shipment.TrackingCode
                                        </a>
                                    </td>
                                    <td>@shipment.ReceiverName</td>
                                    <td>@FormatRouteType(shipment.RouteType)</td>
                                    <td>@shipment.ChargeableWeightKg.ToString("N3") kg</td>
                                    <td>
                                        <span class="status-pill @GetStatusClass(shipment.Status)">
                                            @FormatStatus(shipment.Status)
                                        </span>
                                    </td>
                                    <td>@FormatMoney(shipment.CodAmount, shipment.Currency)</td>
                                    <td>@FormatMoney(shipment.ShippingFeeAmount, shipment.Currency)</td>
                                    <td>@FormatDate(shipment.CreatedAtUtc)</td>
                                    <td>
                                        <a class="icon-link" href="@($"/shipments/{shipment.ShipmentId}")" aria-label="Xem chi tiết">
                                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                                <path d="m9 6 6 6-6 6-1.4-1.4 4.6-4.6-4.6-4.6L9 6Z" />
                                            </svg>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <a class="view-all" href="@(ShipmentItems.Count == 0 ? "/shipments/create" : "/shipments")">
                @(ShipmentItems.Count == 0 ? "Tạo đơn hàng đầu tiên" : "Mở danh sách đơn hàng")
            </a>
        </section>

        <section class="dashboard-bottom">
            <article class="dashboard-card status-card">
                <div class="card-header">
                    <h2>Đơn hàng theo trạng thái</h2>
                    <a class="card-link" href="/shipments">Xem chi tiết</a>
                </div>

                <div class="status-content">
                    <div class="donut-empty">
                        <strong>@ShipmentItems.Count</strong>
                        <span>Tổng đơn</span>
                    </div>

                    <div class="status-list">
                        @foreach (var status in StatusRows)
                        {
                            <div class="status-row">
                                <span class="status-dot @status.ClassName"></span>
                                <p>@status.Label</p>
                                <div class="status-bar"><span style="@($"width: {status.Percentage:N0}%")"></span></div>
                                <strong>@status.Count</strong>
                            </div>
                        }
                    </div>
                </div>
            </article>
        </section>
    }
</div>

@code {
    private static readonly ShipmentStatus[] ActiveShipmentStatuses =
    [
        ShipmentStatus.Assigned,
        ShipmentStatus.PickingUp,
        ShipmentStatus.PickedUp,
        ShipmentStatus.InTransit,
        ShipmentStatus.Delivering
    ];

    private static readonly ShipmentStatus[] PendingCodStatuses =
    [
        ShipmentStatus.PendingPickup,
        ShipmentStatus.Assigned,
        ShipmentStatus.PickingUp,
        ShipmentStatus.PickedUp,
        ShipmentStatus.InTransit,
        ShipmentStatus.Delivering,
        ShipmentStatus.DeliveryFailed
    ];

    private string ShopDisplayName { get; set; } = "Shop";

    private bool IsLoading { get; set; } = true;

    private string? ErrorMessage { get; set; }

    private IReadOnlyList<ShipmentListItemResponse> ShipmentItems { get; set; } = [];

    private IReadOnlyList<ShipmentListItemResponse> LatestShipments { get; set; } = [];

    private IReadOnlyList<DashboardCard> StatisticCards { get; set; } = [];

    private IReadOnlyList<StatusRow> StatusRows { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        var userId = await GetCurrentUserIdAsync();
        if (userId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        var shopResult = await GetCurrentShopService.GetAsync(userId.Value);
        if (shopResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(shopResult.Error);
            IsLoading = false;
            BuildDashboardModel();
            return;
        }

        ShopDisplayName = shopResult.Value.Name;

        var shipmentsResult = await GetShipmentsForCurrentShopService.GetAsync(userId.Value);
        if (shipmentsResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(shipmentsResult.Error);
            IsLoading = false;
            BuildDashboardModel();
            return;
        }

        ShipmentItems = shipmentsResult.Value;
        IsLoading = false;
        BuildDashboardModel();
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userIdValue = authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        return Guid.TryParse(userIdValue, out var userId)
            ? userId
            : null;
    }

    private void BuildDashboardModel()
    {
        LatestShipments = ShipmentItems.Take(5).ToList();

        var totalShipments = ShipmentItems.Count;
        var activeShipments = CountByStatuses(ActiveShipmentStatuses);
        var deliveredShipments = CountByStatus(ShipmentStatus.Delivered);
        var failedShipments = CountByStatus(ShipmentStatus.DeliveryFailed);
        var pendingCodAmount = SumCodByStatuses(PendingCodStatuses);
        var shippingFeeAmount = ShipmentItems.Sum(shipment => shipment.ShippingFeeAmount);
        var currency = ShipmentItems.FirstOrDefault()?.Currency ?? "VND";

        StatisticCards =
        [
            new("Tổng đơn hàng", totalShipments.ToString("N0"), "Tất cả đơn của shop", "blue", BoxIcon),
            new("Đang vận chuyển", activeShipments.ToString("N0"), "Đơn chưa kết thúc", "amber", TruckIcon),
            new("Giao thành công", deliveredShipments.ToString("N0"), "Đơn đã giao", "green", CheckIcon),
            new("Giao thất bại", failedShipments.ToString("N0"), "Cần xử lý lại", "red", CloseIcon),
            new("COD cần thu", FormatMoney(pendingCodAmount, currency), "Theo đơn chưa hoàn tất", "purple", CoinIcon),
            new("Tổng phí vận chuyển", FormatMoney(shippingFeeAmount, currency), "Từ các đơn đã tạo", "blue", WalletIcon)
        ];

        StatusRows =
        [
            CreateStatusRow(ShipmentStatus.PendingPickup, "Chờ lấy hàng", "blue", totalShipments),
            CreateStatusRow(ShipmentStatus.Assigned, "Đã phân công", "amber", totalShipments),
            CreateStatusRow(ShipmentStatus.PickingUp, "Đang lấy hàng", "amber", totalShipments),
            CreateStatusRow(ShipmentStatus.PickedUp, "Đã lấy hàng", "amber", totalShipments),
            CreateStatusRow(ShipmentStatus.InTransit, "Đang vận chuyển", "purple", totalShipments),
            CreateStatusRow(ShipmentStatus.Delivering, "Đang giao", "teal", totalShipments),
            CreateStatusRow(ShipmentStatus.Delivered, "Đã giao", "green", totalShipments),
            CreateStatusRow(ShipmentStatus.DeliveryFailed, "Giao thất bại", "red", totalShipments),
            CreateStatusRow(ShipmentStatus.Returned, "Đã hoàn", "slate", totalShipments),
            CreateStatusRow(ShipmentStatus.Cancelled, "Đã hủy", "slate", totalShipments)
        ];
    }

    private int CountByStatus(ShipmentStatus status)
    {
        return ShipmentItems.Count(shipment => shipment.Status == status);
    }

    private int CountByStatuses(IReadOnlyCollection<ShipmentStatus> statuses)
    {
        return ShipmentItems.Count(shipment => statuses.Contains(shipment.Status));
    }

    private decimal SumCodByStatuses(IReadOnlyCollection<ShipmentStatus> statuses)
    {
        return ShipmentItems
            .Where(shipment => shipment.CodAmount > 0 && statuses.Contains(shipment.Status))
            .Sum(shipment => shipment.CodAmount);
    }

    private StatusRow CreateStatusRow(
        ShipmentStatus status,
        string label,
        string className,
        int totalShipments)
    {
        var count = CountByStatus(status);
        var percentage = totalShipments == 0
            ? 0
            : (decimal)count / totalShipments * 100;

        return new StatusRow(label, className, count, percentage);
    }

    private static string FormatDate(DateTimeOffset value)
    {
        return UiDisplay.FormatLocalDateTime(value);
    }

    private static string FormatMoney(decimal amount, string currency)
    {
        return $"{amount.ToString("N0")} {currency}";
    }

    private static string FormatRouteType(RouteType routeType)
    {
        return routeType switch
        {
            RouteType.IntraProvince => "Nội tỉnh",
            RouteType.IntraRegion => "Nội vùng",
            RouteType.InterRegion => "Liên vùng",
            _ => routeType.ToString()
        };
    }

    private static string FormatStatus(ShipmentStatus status)
    {
        return status switch
        {
            ShipmentStatus.PendingPickup => "Chờ lấy hàng",
            ShipmentStatus.Assigned => "Đã phân công",
            ShipmentStatus.PickingUp => "Đang lấy hàng",
            ShipmentStatus.PickedUp => "Đã lấy hàng",
            ShipmentStatus.InTransit => "Đang vận chuyển",
            ShipmentStatus.Delivering => "Đang giao",
            ShipmentStatus.Delivered => "Đã giao",
            ShipmentStatus.DeliveryFailed => "Giao thất bại",
            ShipmentStatus.Returned => "Đã hoàn",
            ShipmentStatus.Cancelled => "Đã hủy",
            _ => status.ToString()
        };
    }

    private static string GetStatusClass(ShipmentStatus status)
    {
        return status switch
        {
            ShipmentStatus.Delivered => "success",
            ShipmentStatus.Cancelled or ShipmentStatus.DeliveryFailed or ShipmentStatus.Returned => "danger",
            ShipmentStatus.InTransit or ShipmentStatus.Delivering or ShipmentStatus.PickedUp => "info",
            _ => "warning"
        };
    }

    private sealed record DashboardCard(string Label, string Value, string Note, string IconClass, string Icon);

    private sealed record StatusRow(string Label, string ClassName, int Count, decimal Percentage);

    private const string BoxIcon = "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Zm2 1.2v6.6l5 2.8v-6.6L6 8.7Zm7 9.4 5-2.8V8.7l-5 2.8v6.6Zm-6-11L12 10l5-2.9-5-2.8-5 2.8Z\" /></svg>";
    private const string TruckIcon = "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M3 6h11v9h1.4l2-3H21v6h-2a3 3 0 0 1-6 0H9a3 3 0 0 1-6 0H2V8a2 2 0 0 1 1-2Zm2 2v7.8A3 3 0 0 1 8.8 17H13V8H5Zm10 2v5h.6l2-3H19v-2h-4Z\" /></svg>";
    private const string CheckIcon = "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M10.2 15.4 6.8 12l-1.4 1.4 4.8 4.8 8.4-8.4L17.2 8.4l-7 7Z\" /></svg>";
    private const string CloseIcon = "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"m12 10.6 3.5-3.5 1.4 1.4-3.5 3.5 3.5 3.5-1.4 1.4-3.5-3.5-3.5 3.5-1.4-1.4 3.5-3.5-3.5-3.5 1.4-1.4 3.5 3.5Z\" /></svg>";
    private const string CoinIcon = "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Zm1 14h-2v-1.2a4 4 0 0 1-2.4-1.1l1.2-1.6c.8.7 1.5 1 2.5 1 .8 0 1.2-.3 1.2-.8s-.3-.8-1.8-1.1c-1.9-.5-3-1.2-3-2.8 0-1.4 1-2.4 2.3-2.8V5h2v1.4a4.4 4.4 0 0 1 2.1.9L14 8.9c-.7-.5-1.3-.7-2-.7-.7 0-1.1.3-1.1.8 0 .6.4.8 2 1.2 1.9.5 2.8 1.2 2.8 2.8 0 1.5-1 2.5-2.7 2.8V17Z\" /></svg>";
    private const string WalletIcon = "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 5h14v3h2v12H4V5Zm2 2v1h10V7H6Zm0 3v8h12v-2h-5v-4h5v-2H6Zm9 4v1h3v-1h-3Z\" /></svg>";
}
