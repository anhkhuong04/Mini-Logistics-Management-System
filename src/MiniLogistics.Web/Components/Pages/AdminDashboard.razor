@page "/admin"
@page "/admin/dashboard"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using System.Security.Claims
@using MiniLogistics.Application.AdminDashboard
@inject IGetAdminDashboardService GetAdminDashboardService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Admin Dashboard - MiniLogistics</PageTitle>

<div class="admin-dashboard-page">
    <header class="admin-hero">
        <div>
            <p class="eyebrow">Control tower</p>
            <h1>Admin dashboard</h1>
            <p>Tong quan van hanh, shipper, COD, shop va webhook trong mot man hinh.</p>
        </div>

        <button type="button" class="refresh-button" disabled="@IsLoading" @onclick="LoadAsync">Lam moi</button>
    </header>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert-box danger" role="alert">@ErrorMessage</div>
    }

    <section class="admin-panel dashboard-filters">
        <label class="field-group" for="dashboard-from">
            <span>Tu ngay</span>
            <input id="dashboard-from" type="date" value="@FromDateText" @onchange="OnFromDateChanged" />
        </label>

        <label class="field-group" for="dashboard-to">
            <span>Den ngay</span>
            <input id="dashboard-to" type="date" value="@ToDateText" @onchange="OnToDateChanged" />
        </label>

        <label class="field-group" for="dashboard-province">
            <span>Province</span>
            <input id="dashboard-province" placeholder="Tat ca" @bind="ProvinceFilter" @bind:event="oninput" />
        </label>

        <div class="form-actions">
            <button type="button" class="primary-button" disabled="@IsLoading" @onclick="LoadAsync">Ap dung</button>
        </div>
    </section>

    @if (IsLoading)
    {
        <section class="admin-panel state-card" aria-live="polite">
            <strong>Dang tai dashboard</strong>
        </section>
    }
    else if (Dashboard is not null)
    {
        <section class="summary-grid" aria-label="Admin dashboard metrics">
            <a class="metric-card" href="/operations/assignments">
                <span>Don tao trong ky</span>
                <strong>@Dashboard.Shipments.Created.ToString("N0")</strong>
                <small>Khong tinh Draft</small>
            </a>
            <a class="metric-card warning" href="/operations/assignments">
                <span>Pending chua assign</span>
                <strong>@Dashboard.Shipments.PendingPickupUnassigned.ToString("N0")</strong>
                <small>Can retry/assign thu cong</small>
            </a>
            <a class="metric-card danger" href="/operations/assignments">
                <span>Delivery failed</span>
                <strong>@Dashboard.Shipments.DeliveryFailed.ToString("N0")</strong>
                <small>@Dashboard.Shipments.DeliveryFailedRate.ToString("N2")% tren tong non-draft</small>
            </a>
            <a class="metric-card" href="/admin/users">
                <span>Shipper active</span>
                <strong>@Dashboard.Shippers.Active.ToString("N0")</strong>
                <small>@Dashboard.Shippers.AvailableForAssignment.ToString("N0") dang nhan auto assign</small>
            </a>
            <a class="metric-card warning" href="/admin/users">
                <span>Shipper qua capacity</span>
                <strong>@Dashboard.Shippers.OverCapacity.ToString("N0")</strong>
                <small>Theo active assignment load</small>
            </a>
            <a class="metric-card" href="/admin/shops">
                <span>Shop active</span>
                <strong>@Dashboard.Shops.Active.ToString("N0")</strong>
                <small>@Dashboard.Shops.Inactive.ToString("N0") inactive</small>
            </a>
        </section>

        <section class="dashboard-grid">
            <article class="admin-panel dashboard-card">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">COD</p>
                        <h2>Dong tien COD</h2>
                    </div>
                    <a class="panel-link" href="/admin/cod">Mo COD</a>
                </div>

                <div class="stacked-metrics">
                    <div>
                        <span>Pending collection</span>
                        <strong>@FormatMoney(Dashboard.Cod.PendingCollectionAmount, Dashboard.Cod.Currency)</strong>
                        <small>@Dashboard.Cod.PendingCollectionCount.ToString("N0") don</small>
                    </div>
                    <div>
                        <span>Collected waiting settlement</span>
                        <strong>@FormatMoney(Dashboard.Cod.CollectedAwaitingSettlementAmount, Dashboard.Cod.Currency)</strong>
                        <small>@Dashboard.Cod.CollectedAwaitingSettlementCount.ToString("N0") don</small>
                    </div>
                    <div>
                        <span>Settled</span>
                        <strong>@FormatMoney(Dashboard.Cod.SettledAmount, Dashboard.Cod.Currency)</strong>
                        <small>@Dashboard.Cod.SettledCount.ToString("N0") don</small>
                    </div>
                </div>
            </article>

            <article class="admin-panel dashboard-card">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Webhook</p>
                        <h2>Partner delivery health</h2>
                    </div>
                    <a class="panel-link" href="/partner/integrations">Mo API</a>
                </div>

                <div class="stacked-metrics compact">
                    <div>
                        <span>Failed deliveries</span>
                        <strong>@Dashboard.Webhooks.Failed.ToString("N0")</strong>
                    </div>
                    <div>
                        <span>Retry pending</span>
                        <strong>@Dashboard.Webhooks.RetryPending.ToString("N0")</strong>
                    </div>
                </div>
            </article>
        </section>
    }
</div>

@code {
    private bool IsLoading { get; set; } = true;

    private string? ErrorMessage { get; set; }

    private string FromDateText { get; set; } = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");

    private string ToDateText { get; set; } = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");

    private string ProvinceFilter { get; set; } = string.Empty;

    private AdminDashboardResponse? Dashboard { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        var adminUserId = await GetCurrentUserIdAsync();
        if (adminUserId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        var result = await GetAdminDashboardService.GetAsync(new AdminDashboardQuery(
            adminUserId.Value,
            ParseStartDate(FromDateText),
            ParseEndDate(ToDateText),
            string.IsNullOrWhiteSpace(ProvinceFilter) ? null : ProvinceFilter.Trim()));

        IsLoading = false;
        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            Dashboard = null;
            return;
        }

        Dashboard = result.Value;
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userIdValue = authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        return Guid.TryParse(userIdValue, out var userId)
            ? userId
            : null;
    }

    private void OnFromDateChanged(ChangeEventArgs args)
    {
        FromDateText = args.Value?.ToString() ?? string.Empty;
    }

    private void OnToDateChanged(ChangeEventArgs args)
    {
        ToDateText = args.Value?.ToString() ?? string.Empty;
    }

    private static DateTimeOffset? ParseStartDate(string value)
    {
        return DateOnly.TryParse(value, out var date)
            ? date.ToDateTime(TimeOnly.MinValue, DateTimeKind.Local).ToUniversalTime()
            : null;
    }

    private static DateTimeOffset? ParseEndDate(string value)
    {
        return DateOnly.TryParse(value, out var date)
            ? date.ToDateTime(TimeOnly.MaxValue, DateTimeKind.Local).ToUniversalTime()
            : null;
    }

    private static string FormatMoney(decimal amount, string currency)
    {
        return $"{amount:N0} {currency}";
    }
}
