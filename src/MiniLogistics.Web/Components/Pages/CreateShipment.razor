    }

    private bool TryClassifyRoute()
    {
        if (string.IsNullOrWhiteSpace(Form.PickupProvince)
            || string.IsNullOrWhiteSpace(Form.DeliveryProvince))
        {
            return false;
        }

        var routeClassificationResult = RouteClassificationService.Classify(
            Form.PickupProvince,
            Form.DeliveryProvince);

        if (routeClassificationResult.IsFailure)
        {
            FeeEstimateMessage = UiDisplay.ToErrorMessage(routeClassificationResult.Error);
            return false;
        }

        Form.RouteType = routeClassificationResult.Value.RouteType;
        return true;
    }

    private IReadOnlyList<WardOption> GetWardOptions(string provinceName, string? fallbackWard = null)
    {
        var province = Provinces.FirstOrDefault(province => province.Name == provinceName);
        if (province is null)
        {
            return string.IsNullOrWhiteSpace(fallbackWard)
                ? []
                : [new WardOption(fallbackWard)];
        }

        if (!string.IsNullOrWhiteSpace(fallbackWard)
            && !province.Wards.Any(ward => ward.Name == fallbackWard))
        {
            return province.Wards
                .Append(new WardOption(fallbackWard))
                .OrderBy(ward => ward.Name)
                .ToList();
        }

        return province.Wards;
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userIdValue = authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        return Guid.TryParse(userIdValue, out var userId)
            ? userId
            : null;
    }

