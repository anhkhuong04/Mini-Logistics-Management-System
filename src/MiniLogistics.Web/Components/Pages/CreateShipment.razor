        return new CreateShipmentFormModel
        {
            SenderName = string.Empty,
            SenderPhone = string.Empty,
            PickupStreet = string.Empty,
            PickupWard = string.Empty,
            PickupProvince = string.Empty,
            ReceiverName = string.Empty,
            ReceiverPhone = string.Empty,
            DeliveryStreet = string.Empty,
            DeliveryWard = string.Empty,
            DeliveryProvince = string.Empty,
            WeightKg = 1,
            LengthCm = 20,
            WidthCm = 10,
            HeightCm = 10,
            GoodsValueAmount = 0,
            CodAmount = 0,
            RouteType = RouteType.IntraProvince
        };
    }

    private void ResetFeeBreakdown()
    {
        EstimatedBaseFeeAmount = 0;
        EstimatedExtraWeightFeeAmount = 0;
        EstimatedInsuranceFeeAmount = 0;
        EstimatedReturnFeeAmount = 0;
    }

    private static string FormatMoney(decimal amount, string currency)
    {
        return $"{amount.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)} {currency}";
    }

    private static string FormatRouteType(RouteType routeType)
    {
        return routeType switch
        {
            RouteType.IntraProvince => "Nội tỉnh",
            RouteType.IntraRegion => "Nội vùng",
            RouteType.InterRegion => "Liên vùng",
            _ => routeType.ToString()
        };
    }

