@page "/shipments/create"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Shop")]
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using MiniLogistics.Application.Fees
@using MiniLogistics.Application.Routing
@using MiniLogistics.Application.Shops.GetShopContext
@using MiniLogistics.Application.Shipments.CreateShipment
@using MiniLogistics.Application.Shipments.DraftShipments
@using MiniLogistics.Application.Shipments.GetShipmentDetailForCurrentShop
@using MiniLogistics.Domain.Shipments
@using MiniLogistics.Domain.ValueObjects
@using MiniLogistics.Web.Services
@inject IGetShopContextService GetShopContextService
@inject ICreateShipmentService CreateShipmentService
@inject ICreateDraftShipmentService CreateDraftShipmentService
@inject IUpdateShipmentBeforePickupService UpdateShipmentBeforePickupService
@inject ISubmitDraftShipmentService SubmitDraftShipmentService
@inject IGetShipmentDetailForCurrentShopService GetShipmentDetailForCurrentShopService
@inject IShippingFeeService ShippingFeeService
@inject IRouteClassificationService RouteClassificationService
@inject VietnamAdministrativeDivisionService AdministrativeDivisionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Tạo đơn hàng mới</PageTitle>

<div class="shipment-page">
    <div class="page-heading">
        <div>
            <h1>Tạo đơn hàng mới</h1>
            <nav class="breadcrumb-line" aria-label="Breadcrumb">
                <a href="@(BuildShopLink("/dashboard"))">Trang chủ</a>
                <span>/</span>
                <a href="@(BuildShopLink("/shipments"))">Đơn hàng</a>
                <span>/</span>
                <strong>Tạo đơn hàng</strong>
            </nav>
        </div>
    </div>

    @if (ShopContext is not null)
    {
        <section class="shop-context-bar" aria-label="Shop context">
            <label for="create-shop-context">
                Shop dang chon
                <select id="create-shop-context" value="@SelectedShopId" @onchange="OnShopChanged">
                    @foreach (var shop in ShopContext.Shops)
                    {
                        <option value="@shop.ShopId">
                            @shop.Name@(shop.IsActive ? string.Empty : " (Inactive)")
                        </option>
                    }
                </select>
            </label>
            <span class="shop-context-status @(SelectedShop?.IsActive == true ? "active" : "inactive")">
                @(SelectedShop?.IsActive == true ? "Active" : "Inactive")
            </span>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@ErrorMessage</div>
    }

    @if (CreatedShipment is not null)
    {
        <div class="alert alert-success success-alert" role="status">
            <span>
                Đã tạo vận đơn <strong>@CreatedShipment.TrackingCode</strong>.
                Phí vận chuyển: <strong>@FormatMoney(CreatedShipment.ShippingFeeAmount, CreatedShipment.Currency)</strong>.
            </span>
            <a class="fw-bold" href="@(BuildShopLink($"/shipments/{CreatedShipment.ShipmentId}"))">Xem chi tiết</a>
    </div>
    }

    @if (SavedShipment is not null)
    {
        <div class="alert alert-success success-alert" role="status">
            <span>
                @SuccessMessage <strong>@SavedShipment.TrackingCode</strong>.
                Phi van chuyen: <strong>@FormatMoney(SavedShipment.ShippingFeeAmount, SavedShipment.Currency)</strong>.
            </span>
            <a class="fw-bold" href="@(BuildShopLink($"/shipments/{SavedShipment.ShipmentId}"))">Xem chi tiet</a>
        </div>

        @if (SavedShipment.FeeChanged)
        {
            <div class="alert alert-warning" role="status">
                Phi van chuyen da thay doi tu @FormatMoney(SavedShipment.PreviousShippingFeeAmount!.Value, SavedShipment.Currency)
                sang @FormatMoney(SavedShipment.ShippingFeeAmount, SavedShipment.Currency).
            </div>
        }
    }

    @if (ShopContext is not null && SelectedShop?.IsActive == false)
    {
        <div class="alert alert-warning" role="status">
            Shop dang inactive. Ban co the xem du lieu lich su, nhung khong the tao don hang moi cho shop nay.
        </div>
    }

    <EditForm Model="Form" OnValidSubmit="HandleSubmitAsync" class="create-layout">
        <DataAnnotationsValidator />

        <div class="form-stack">
            <section class="form-section">
                <div class="section-heading">
                    <span class="section-icon blue">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-3.3 0-6 1.7-6 3.8V20h12v-2.2c0-2.1-2.7-3.8-6-3.8Z" />
                        </svg>
                    </span>
                    <div>
                        <h2>1. Thông tin người gửi</h2>
                        <p>Lấy mặc định từ hồ sơ shop và được khóa khi tạo đơn.</p>
                    </div>
                    <span class="collapse-mark">⌃</span>
                </div>

                <div class="form-grid sender-grid">
                    <div class="form-field">
                        <label for="sender-name">Tên người gửi <span>*</span></label>
                        <InputText id="sender-name" class="form-control" @bind-Value="Form.SenderName" disabled="@(!IsEditMode)" />
                        <ValidationMessage For="() => Form.SenderName" />
                    </div>

                    <div class="form-field">
                        <label for="sender-phone">Số điện thoại <span>*</span></label>
                        <InputText id="sender-phone" class="form-control" @bind-Value="Form.SenderPhone" disabled="@(!IsEditMode)" />
                        <ValidationMessage For="() => Form.SenderPhone" />
                    </div>

                    <div class="form-field wide">
                        <label for="pickup-street">Địa chỉ lấy hàng <span>*</span></label>
                        <InputText id="pickup-street" class="form-control" @bind-Value="Form.PickupStreet" disabled="@(!IsEditMode)" />
                        <ValidationMessage For="() => Form.PickupStreet" />
                    </div>

                    <div class="form-field">
                        <label for="pickup-province">Tỉnh / Thành <span>*</span></label>
                        <InputSelect id="pickup-province" class="form-select" @bind-Value="Form.PickupProvince" @bind-Value:after="HandlePickupProvinceChanged" disabled="@(!IsEditMode)">
                            @foreach (var province in Provinces)
                            {
                                <option value="@province.Name">@province.Name</option>
                            }
                            @if (!string.IsNullOrWhiteSpace(Form.PickupProvince) && !Provinces.Any(province => province.Name == Form.PickupProvince))
                            {
                                <option value="@Form.PickupProvince">@Form.PickupProvince</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => Form.PickupProvince" />
                    </div>

                    <div class="form-field">
                        <label for="pickup-ward">Phường / Xã <span>*</span></label>
                        <InputSelect id="pickup-ward" class="form-select" @bind-Value="Form.PickupWard" disabled="@(!IsEditMode || !PickupWardOptions.Any())">
                            @foreach (var ward in PickupWardOptions)
                            {
                                <option value="@ward.Name">@ward.Name</option>
                            }
                            @if (!string.IsNullOrWhiteSpace(Form.PickupWard) && !PickupWardOptions.Any(ward => ward.Name == Form.PickupWard))
                            {
                                <option value="@Form.PickupWard">@Form.PickupWard</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => Form.PickupWard" />
                    </div>
                </div>
            </section>

            <section class="form-section">
                <div class="section-heading">
                    <span class="section-icon green">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm7 8H5v-1.5C5 15.5 8.1 14 12 14s7 1.5 7 4.5V20Z" />
                        </svg>
                    </span>
                    <h2>2. Thông tin người nhận</h2>
                    <span class="collapse-mark">⌃</span>
                </div>

                <div class="form-grid">
                    <div class="form-field">
                        <label for="receiver-name">Tên người nhận <span>*</span></label>
                        <InputText id="receiver-name" class="form-control" @bind-Value="Form.ReceiverName" />
                        <ValidationMessage For="() => Form.ReceiverName" />
                    </div>

                    <div class="form-field">
                        <label for="receiver-phone">Số điện thoại <span>*</span></label>
                        <InputText id="receiver-phone" class="form-control" @bind-Value="Form.ReceiverPhone" />
                        <ValidationMessage For="() => Form.ReceiverPhone" />
                    </div>

                    <div class="form-field wide">
                        <label for="delivery-street">Địa chỉ giao hàng <span>*</span></label>
                        <InputText id="delivery-street" class="form-control" @bind-Value="Form.DeliveryStreet" />
                        <ValidationMessage For="() => Form.DeliveryStreet" />
                    </div>

                    <div class="form-field">
                        <label for="delivery-province">Tỉnh / Thành <span>*</span></label>
                        <InputSelect id="delivery-province" class="form-select" @bind-Value="Form.DeliveryProvince" @bind-Value:after="HandleDeliveryProvinceChanged">
                            <option value="">Chọn Tỉnh / Thành</option>
                            @foreach (var province in Provinces)
                            {
                                <option value="@province.Name">@province.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => Form.DeliveryProvince" />
                    </div>

                    <div class="form-field">
                        <label for="delivery-ward">Phường / Xã <span>*</span></label>
                        <InputSelect id="delivery-ward" class="form-select" @bind-Value="Form.DeliveryWard" disabled="@(!DeliveryWardOptions.Any())">
                            <option value="">Chọn Phường / Xã</option>
                            @foreach (var ward in DeliveryWardOptions)
                            {
                                <option value="@ward.Name">@ward.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => Form.DeliveryWard" />
                    </div>
                </div>
            </section>

            <section class="form-section">
                <div class="section-heading">
                    <span class="section-icon orange">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Zm2 1.2v6.6l5 2.8v-6.6L6 8.7Zm7 9.4 5-2.8V8.7l-5 2.8v6.6Zm-6-11L12 10l5-2.9-5-2.8-5 2.8Z" />
                        </svg>
                    </span>
                    <h2>3. Thông tin hàng hóa</h2>
                    <span class="collapse-mark">⌃</span>
                </div>

                <div class="form-grid package-grid">
                    <div class="form-field">
                        <label for="route-type">Tuyến đường <span>*</span></label>
                        <input id="route-type" class="form-control" value="@FormatRouteType(Form.RouteType)" readonly />
                        <ValidationMessage For="() => Form.RouteType" />
                    </div>

                    <div class="form-field">
                        <label for="weight">Khối lượng (kg) <span>*</span></label>
                        <InputNumber id="weight" class="form-control" @bind-Value="Form.WeightKg" @bind-Value:after="CalculateFeeEstimateAsync" />
                        <ValidationMessage For="() => Form.WeightKg" />
                    </div>

                    <div class="form-field">
                        <label for="length">Chiều dài (cm) <span>*</span></label>
                        <InputNumber id="length" class="form-control" @bind-Value="Form.LengthCm" @bind-Value:after="CalculateFeeEstimateAsync" />
                        <ValidationMessage For="() => Form.LengthCm" />
                    </div>

                    <div class="form-field">
                        <label for="width">Chiều rộng (cm) <span>*</span></label>
                        <InputNumber id="width" class="form-control" @bind-Value="Form.WidthCm" @bind-Value:after="CalculateFeeEstimateAsync" />
                        <ValidationMessage For="() => Form.WidthCm" />
                    </div>

                    <div class="form-field">
                        <label for="height">Chiều cao (cm) <span>*</span></label>
                        <InputNumber id="height" class="form-control" @bind-Value="Form.HeightCm" @bind-Value:after="CalculateFeeEstimateAsync" />
                        <ValidationMessage For="() => Form.HeightCm" />
                    </div>

                    <div class="form-field">
                        <label for="goods-value">Giá trị hàng hóa (đ)</label>
                        <InputNumber id="goods-value" class="form-control" @bind-Value="Form.GoodsValueAmount" @bind-Value:after="CalculateFeeEstimateAsync" />
                        <ValidationMessage For="() => Form.GoodsValueAmount" />
                    </div>

                    <div class="chargeable-box">
                        <span>Khối lượng quy đổi</span>
                        <strong>@EstimatedVolumetricWeightKg.ToString("N3") kg</strong>
                        <small>Cân tính phí: @EstimatedChargeableWeightKg.ToString("N3") kg</small>
                    </div>
                </div>
            </section>

            <section class="form-section">
                <div class="section-heading">
                    <span class="section-icon purple">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Zm1 14h-2v-1.2a4 4 0 0 1-2.4-1.1l1.2-1.6c.8.7 1.5 1 2.5 1 .8 0 1.2-.3 1.2-.8s-.3-.8-1.8-1.1c-1.9-.5-3-1.2-3-2.8 0-1.4 1-2.4 2.3-2.8V5h2v1.4a4.4 4.4 0 0 1 2.1.9L14 8.9c-.7-.5-1.3-.7-2-.7-.7 0-1.1.3-1.1.8 0 .6.4.8 2 1.2 1.9.5 2.8 1.2 2.8 2.8 0 1.5-1 2.5-2.7 2.8V17Z" />
                        </svg>
                    </span>
                    <h2>4. COD & Phí vận chuyển</h2>
                    <span class="collapse-mark">⌃</span>
                </div>

                <div class="form-grid cod-grid">
                    <div class="form-field">
                        <label for="cod-amount">COD (đ)</label>
                        <InputNumber id="cod-amount" class="form-control" @bind-Value="Form.CodAmount" />
                        <ValidationMessage For="() => Form.CodAmount" />
                    </div>

                    <div class="form-field">
                        <label for="cod-method">Hình thức COD</label>
                        <input id="cod-method" class="form-control" value="Thu tiền mặt" disabled />
                    </div>

                    <div class="fee-box">
                        <div>
                            <span>Phí vận chuyển</span>
                            <strong>@FormatMoney(CurrentShippingFeeAmount, CurrentCurrency)</strong>
                        </div>
                        <button type="button" class="recalculate-button" @onclick="CalculateFeeEstimateAsync" disabled="@IsFeeEstimateLoading">
                            @(IsFeeEstimateLoading ? "Đang tính..." : "Tính lại")
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(FeeEstimateMessage))
                    {
                        <p class="fee-note">@FeeEstimateMessage</p>
                    }
                    else
                    {
                        <p class="fee-note">Phí vận chuyển tính theo tuyến, cân thực tế và cân quy đổi từ kích thước.</p>
                    }

                    <dl class="fee-breakdown">
                        <div>
                            <dt>Phí dịch vụ chính</dt>
                            <dd>@FormatMoney(CurrentBaseFeeAmount, CurrentCurrency)</dd>
                        </div>
                        <div>
                            <dt>Phí vượt cân</dt>
                            <dd>@FormatMoney(CurrentExtraWeightFeeAmount, CurrentCurrency)</dd>
                        </div>
                        <div>
                            <dt>Phí bảo hiểm</dt>
                            <dd>@FormatMoney(CurrentInsuranceFeeAmount, CurrentCurrency)</dd>
                        </div>
                        <div>
                            <dt>Phí hoàn hàng</dt>
                            <dd>@FormatMoney(CurrentReturnFeeAmount, CurrentCurrency)</dd>
                        </div>
                    </dl>
                </div>
            </section>

            <section class="form-section">
                <div class="section-heading">
                    <span class="section-icon blue">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M6 3h12v18H6V3Zm2 2v14h8V5H8Zm2 3h4v2h-4V8Zm0 4h4v2h-4v-2Z" />
                        </svg>
                    </span>
                    <h2>5. Ghi chú đơn hàng</h2>
                    <span class="collapse-mark">⌃</span>
                </div>

                <div class="form-field">
                    <label for="note">Ghi chú cho đơn hàng</label>
                    <InputTextArea id="note" class="form-control" rows="3" placeholder="Ví dụ: Hàng dễ vỡ, cần nhẹ tay..." @bind-Value="Form.Note" />
                    <ValidationMessage For="() => Form.Note" />
                </div>
            </section>
        </div>

        <aside class="summary-card">
            <h2>Tóm tắt đơn hàng</h2>

            <div class="summary-code">
                <span>Mã đơn hàng</span>
                <strong>@CurrentTrackingCode</strong>
            </div>

            <dl class="summary-list">
                <div>
                    <dt>
                        <span class="summary-icon blue">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 4 20h16L12 2Zm0 5.2 4.7 10.8H7.3L12 7.2Z" /></svg>
                        </span>
                        Tuyến đường
                    </dt>
                    <dd>@FormatRouteType(Form.RouteType)</dd>
                </div>
                <div>
                    <dt>
                        <span class="summary-icon cyan">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 4h10l2 6v10H5V10l2-6Zm1.4 2-1 3h9.2l-1-3H8.4ZM7 11v7h10v-7H7Z" /></svg>
                        </span>
                        Khối lượng
                    </dt>
                    <dd>@Form.WeightKg.ToString("N3") kg</dd>
                </div>
                <div>
                    <dt>
                        <span class="summary-icon cyan">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Zm2 1.2v6.6l5 2.8v-6.6L6 8.7Zm7 9.4 5-2.8V8.7l-5 2.8v6.6Zm-6-11L12 10l5-2.9-5-2.8-5 2.8Z" /></svg>
                        </span>
                        Cân tính phí
                    </dt>
                    <dd>@EstimatedChargeableWeightKg.ToString("N3") kg</dd>
                </div>
                <div>
                    <dt>
                        <span class="summary-icon green">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Zm1 14h-2v-1.2a4 4 0 0 1-2.4-1.1l1.2-1.6c.8.7 1.5 1 2.5 1 .8 0 1.2-.3 1.2-.8s-.3-.8-1.8-1.1c-1.9-.5-3-1.2-3-2.8 0-1.4 1-2.4 2.3-2.8V5h2v1.4a4.4 4.4 0 0 1 2.1.9L14 8.9c-.7-.5-1.3-.7-2-.7-.7 0-1.1.3-1.1.8 0 .6.4.8 2 1.2 1.9.5 2.8 1.2 2.8 2.8 0 1.5-1 2.5-2.7 2.8V17Z" /></svg>
                        </span>
                        COD
                    </dt>
                    <dd>@FormatMoney(Form.CodAmount, CurrentCurrency)</dd>
                </div>
                <div>
                    <dt>
                        <span class="summary-icon blue">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h14v16H5V4Zm2 2v12h10V6H7Zm2 2h6v2H9V8Zm0 4h6v2H9v-2Z" /></svg>
                        </span>
                        Phí vận chuyển
                    </dt>
                    <dd>@FormatMoney(CurrentShippingFeeAmount, CurrentCurrency)</dd>
                </div>
                <div>
                    <dt>Phí dịch vụ chính</dt>
                    <dd>@FormatMoney(CurrentBaseFeeAmount, CurrentCurrency)</dd>
                </div>
                <div>
                    <dt>Phí vượt cân</dt>
                    <dd>@FormatMoney(CurrentExtraWeightFeeAmount, CurrentCurrency)</dd>
                </div>
            </dl>

            <div class="total-box">
                <span>Tổng tiền thu hộ</span>
                <strong>@FormatMoney(Form.CodAmount + CurrentShippingFeeAmount, CurrentCurrency)</strong>
                <small>COD + Phí vận chuyển</small>
            </div>

            <div class="hint-box">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M11 18h2v-2h-2v2Zm1-16a8 8 0 0 0-5 14.2V21l5-2 5 2v-4.8A8 8 0 0 0 12 2Zm0 2a6 6 0 0 1 3.5 10.9l-.5.3v2.8l-3-1.2-3 1.2v-2.8l-.5-.3A6 6 0 0 1 12 4Zm-1 4h2v6h-2V8Z" />
                </svg>
                <span>@SummaryHintText</span>
            </div>

            <button type="submit" class="btn btn-primary submit-button" disabled="@(!CanSubmit)">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M2 21 23 3 17 21l-5-7-7 7H2Zm13.7-4.8 2.8-8.4-9 7.7 3.2-3.2 3 3.9Z" />
                </svg>
                <span>@PrimarySubmitButtonText</span>
            </button>

            @if (CanShowSaveDraftButton)
            {
                <button type="button" class="btn btn-outline-secondary reset-button" @onclick="HandleSaveDraftAsync" disabled="@(!CanSaveDraft)">
                    @(IsSavingDraft ? "Dang luu nhap..." : "Luu nhap")
                </button>
            }

            <button type="button" class="btn btn-outline-secondary reset-button" @onclick="ResetFormAsync" disabled="@IsBusy">
                Hủy
            </button>
        </aside>
    </EditForm>
</div>

@code {
    [SupplyParameterFromQuery(Name = "shopId")]
    public Guid? ShopId { get; set; }

    [SupplyParameterFromQuery(Name = "shipmentId")]
    public Guid? ShipmentId { get; set; }

    private CreateShipmentFormModel Form { get; set; } = CreateDefaultForm();

    private GetShopContextResponse? ShopContext { get; set; }

    private Guid SelectedShopId { get; set; }

    private ShopContextItemResponse? SelectedShop => ShopContext?.Shops
        .FirstOrDefault(shop => shop.ShopId == SelectedShopId);

    private bool IsSubmitting { get; set; }

    private bool IsSavingDraft { get; set; }

    private bool IsSubmittingDraft { get; set; }

    private bool IsFeeEstimateLoading { get; set; }

    private string? ErrorMessage { get; set; }

    private string? FeeEstimateMessage { get; set; }

    private string? SuccessMessage { get; set; }

    private decimal EstimatedShippingFeeAmount { get; set; }

    private decimal EstimatedBaseFeeAmount { get; set; }

    private decimal EstimatedExtraWeightFeeAmount { get; set; }

    private decimal EstimatedInsuranceFeeAmount { get; set; }

    private decimal EstimatedReturnFeeAmount { get; set; }

    private decimal EstimatedVolumetricWeightKg { get; set; }

    private decimal EstimatedChargeableWeightKg { get; set; } = 1;

    private string EstimatedShippingFeeCurrency { get; set; } = "VND";

    private CreateShipmentResponse? CreatedShipment { get; set; }

    private DraftShipmentResponse? SavedShipment { get; set; }

    private ShipmentDetailResponse? EditingShipment { get; set; }

    private IReadOnlyList<ProvinceOption> Provinces { get; set; } = [];

    private IReadOnlyList<WardOption> PickupWardOptions { get; set; } = [];

    private IReadOnlyList<WardOption> DeliveryWardOptions { get; set; } = [];

    private decimal CurrentShippingFeeAmount => CreatedShipment?.ShippingFeeAmount
        ?? SavedShipment?.ShippingFeeAmount
        ?? EstimatedShippingFeeAmount;

    private decimal CurrentBaseFeeAmount => CreatedShipment?.BaseFeeAmount
        ?? SavedShipment?.BaseFeeAmount
        ?? EstimatedBaseFeeAmount;

    private decimal CurrentExtraWeightFeeAmount => CreatedShipment?.ExtraWeightFeeAmount
        ?? SavedShipment?.ExtraWeightFeeAmount
        ?? EstimatedExtraWeightFeeAmount;

    private decimal CurrentInsuranceFeeAmount => CreatedShipment?.InsuranceFeeAmount
        ?? SavedShipment?.InsuranceFeeAmount
        ?? EstimatedInsuranceFeeAmount;

    private decimal CurrentReturnFeeAmount => CreatedShipment?.ReturnFeeAmount
        ?? SavedShipment?.ReturnFeeAmount
        ?? EstimatedReturnFeeAmount;

    private string CurrentCurrency => CreatedShipment?.Currency
        ?? SavedShipment?.Currency
        ?? EstimatedShippingFeeCurrency;

    private ShipmentStatus? EditingStatus => EditingShipment?.Status;

    private bool IsEditMode => ShipmentId.HasValue;

    private bool IsBusy => IsSubmitting || IsSavingDraft || IsSubmittingDraft;

    private bool CanSubmit => !IsBusy
        && SelectedShop?.IsActive == true
        && (!IsEditMode || EditingStatus is ShipmentStatus.Draft or ShipmentStatus.PendingPickup);

    private bool CanSaveDraft => !IsBusy
        && SelectedShop?.IsActive == true
        && (!IsEditMode || EditingStatus == ShipmentStatus.Draft);

    private bool CanShowSaveDraftButton => !IsEditMode || EditingStatus == ShipmentStatus.Draft;

    private string CurrentTrackingCode => CreatedShipment?.TrackingCode
        ?? SavedShipment?.TrackingCode
        ?? EditingShipment?.TrackingCode
        ?? "Se sinh sau khi tao";

    private string SummaryHintText => IsEditMode
        ? "He thong se tinh lai phi server-side khi luu hoac gui don."
        : "Tao don that se xu ly ngay; luu nhap se chua auto assign.";

    private string PrimarySubmitButtonText
    {
        get
        {
            if (IsSubmitting || IsSubmittingDraft)
            {
                return IsEditMode && EditingStatus == ShipmentStatus.Draft
                    ? "Dang gui don..."
                    : "Dang luu...";
            }

            if (!IsEditMode)
            {
                return "Tao don hang";
            }

            return EditingStatus == ShipmentStatus.Draft
                ? "Gui don"
                : "Luu thay doi";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        Provinces = await AdministrativeDivisionService.GetProvincesAsync();
        ErrorMessage = null;
        CreatedShipment = null;
        SavedShipment = null;
        SuccessMessage = null;
        EditingShipment = null;

        var userId = await GetCurrentUserIdAsync();
        if (userId is null)
        {
            return;
        }

        var contextResult = await GetShopContextService.GetAsync(userId.Value, ShopId);
        if (contextResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(contextResult.Error);
            return;
        }

        ShopContext = contextResult.Value;
        SelectedShopId = contextResult.Value.SelectedShopId;

        if (ShipmentId.HasValue)
        {
            await LoadEditableShipmentAsync(userId.Value);
        }
        else
        {
            Form.SenderName = SelectedShop?.Name ?? string.Empty;
            Form.SenderPhone = SelectedShop?.PhoneNumber ?? string.Empty;
            Form.PickupStreet = SelectedShop?.AddressLine ?? string.Empty;
            Form.PickupWard = SelectedShop?.Ward ?? string.Empty;
            Form.PickupProvince = SelectedShop?.Province ?? string.Empty;
            PickupWardOptions = GetWardOptions(Form.PickupProvince, Form.PickupWard);
        }

        await CalculateFeeEstimateAsync();
    }

    private async Task LoadEditableShipmentAsync(Guid userId)
    {
        if (!ShipmentId.HasValue)
        {
            return;
        }

        var result = await GetShipmentDetailForCurrentShopService.GetAsync(
            userId,
            ShipmentId.Value,
            SelectedShopId);
        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            return;
        }

        if (result.Value.Status is not (ShipmentStatus.Draft or ShipmentStatus.PendingPickup))
        {
            ErrorMessage = "Chi co the sua don nhap hoac don cho lay hang.";
            return;
        }

        EditingShipment = result.Value;
        PopulateForm(result.Value);
    }

    private void PopulateForm(ShipmentDetailResponse shipment)
    {
        Form.SenderName = shipment.SenderName;
        Form.SenderPhone = shipment.SenderPhone;
        Form.PickupStreet = shipment.PickupAddress.Street;
        Form.PickupWard = shipment.PickupAddress.Ward;
        Form.PickupProvince = shipment.PickupAddress.Province;
        PickupWardOptions = GetWardOptions(Form.PickupProvince, Form.PickupWard);

        Form.ReceiverName = shipment.ReceiverName;
        Form.ReceiverPhone = shipment.ReceiverPhone;
        Form.DeliveryStreet = shipment.DeliveryAddress.Street;
        Form.DeliveryWard = shipment.DeliveryAddress.Ward;
        Form.DeliveryProvince = shipment.DeliveryAddress.Province;
        DeliveryWardOptions = GetWardOptions(Form.DeliveryProvince, Form.DeliveryWard);

        Form.WeightKg = shipment.WeightKg;
        Form.LengthCm = shipment.ParcelLengthCm;
        Form.WidthCm = shipment.ParcelWidthCm;
        Form.HeightCm = shipment.ParcelHeightCm;
        Form.GoodsValueAmount = shipment.GoodsValueAmount;
        Form.CodAmount = shipment.CodAmount;
        Form.RouteType = shipment.RouteType;
        Form.Note = shipment.Note;

        EstimatedShippingFeeAmount = shipment.ShippingFeeAmount;
        EstimatedBaseFeeAmount = shipment.BaseFeeAmount;
        EstimatedExtraWeightFeeAmount = shipment.ExtraWeightFeeAmount;
        EstimatedInsuranceFeeAmount = shipment.InsuranceFeeAmount;
        EstimatedReturnFeeAmount = shipment.ReturnFeeAmount;
        EstimatedVolumetricWeightKg = shipment.VolumetricWeightKg;
        EstimatedChargeableWeightKg = shipment.ChargeableWeightKg;
        EstimatedShippingFeeCurrency = shipment.Currency;
    }

    private async Task HandleSubmitAsync()
    {
        ErrorMessage = null;
        CreatedShipment = null;
        SavedShipment = null;
        SuccessMessage = null;

        try
        {
            var userId = await GetCurrentUserIdAsync();
            if (userId is null)
            {
                NavigationManager.NavigateTo("/login", forceLoad: true);
                return;
            }

            if (IsEditMode && EditingStatus == ShipmentStatus.Draft)
            {
                await SubmitDraftFromFormAsync(userId.Value);
                return;
            }

            if (IsEditMode)
            {
                await UpdateBeforePickupAsync(userId.Value, "Da luu thay doi cho don hang");
                return;
            }

            await CreateShipmentAsync(userId.Value);
        }
        finally
        {
            IsSubmitting = false;
            IsSubmittingDraft = false;
        }
    }

    private async Task HandleSaveDraftAsync()
    {
        ErrorMessage = null;
        CreatedShipment = null;
        SavedShipment = null;
        SuccessMessage = null;

        var userId = await GetCurrentUserIdAsync();
        if (userId is null)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        IsSavingDraft = true;

        try
        {
            if (IsEditMode)
            {
                await UpdateBeforePickupAsync(userId.Value, "Da luu nhap");
            }
            else
            {
                var result = await CreateDraftShipmentService.CreateAsync(
                    BuildCreateDraftCommand(userId.Value));
                if (result.IsFailure)
                {
                    ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
                    return;
                }

                SavedShipment = result.Value;
                SuccessMessage = "Da luu nhap";
                ShipmentId = result.Value.ShipmentId;
                SetEstimate(result.Value);
                await RefreshEditingShipmentAsync(userId.Value);
            }
        }
        finally
        {
            IsSavingDraft = false;
            IsSubmitting = false;
            IsSubmittingDraft = false;
        }
    }

    private async Task CreateShipmentAsync(Guid userId)
    {
        IsSubmitting = true;

        var result = await CreateShipmentService.CreateAsync(BuildCreateCommand(userId));
        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            return;
        }

        CreatedShipment = result.Value;
        SetEstimate(result.Value);
    }

    private async Task UpdateBeforePickupAsync(Guid userId, string successMessage)
    {
        if (!ShipmentId.HasValue)
        {
            ErrorMessage = "Shipment id is required.";
            return;
        }

        IsSubmitting = true;

        var result = await UpdateShipmentBeforePickupService.UpdateAsync(
            BuildUpdateCommand(userId, ShipmentId.Value));
        if (result.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(result.Error);
            return;
        }

        SavedShipment = result.Value;
        SuccessMessage = successMessage;
        SetEstimate(result.Value);
        await RefreshEditingShipmentAsync(userId);
    }

    private async Task SubmitDraftFromFormAsync(Guid userId)
    {
        if (!ShipmentId.HasValue)
        {
            ErrorMessage = "Shipment id is required.";
            return;
        }

        IsSubmittingDraft = true;

        var updateResult = await UpdateShipmentBeforePickupService.UpdateAsync(
            BuildUpdateCommand(userId, ShipmentId.Value));
        if (updateResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(updateResult.Error);
            return;
        }

        var submitResult = await SubmitDraftShipmentService.SubmitAsync(new SubmitDraftShipmentCommand(
            userId,
            ShipmentId.Value,
            SelectedShopId));
        if (submitResult.IsFailure)
        {
            ErrorMessage = UiDisplay.ToErrorMessage(submitResult.Error);
            return;
        }

        SavedShipment = submitResult.Value;
        SuccessMessage = "Da gui don";
        SetEstimate(submitResult.Value);
        await RefreshEditingShipmentAsync(userId);
    }

    private async Task RefreshEditingShipmentAsync(Guid userId)
    {
        if (!ShipmentId.HasValue)
        {
            return;
        }

        var result = await GetShipmentDetailForCurrentShopService.GetAsync(
            userId,
            ShipmentId.Value,
            SelectedShopId);
        if (result.IsSuccess)
        {
            EditingShipment = result.Value;
        }
    }

