    private async Task CalculateFeeEstimateAsync()
    {
        FeeEstimateMessage = null;
        CreatedShipment = null;
        SavedShipment = null;

        if (!TryClassifyRoute())
        {
            EstimatedShippingFeeAmount = 0;
            ResetFeeBreakdown();
            FeeEstimateMessage ??= "Chọn đầy đủ tỉnh lấy hàng và tỉnh giao hàng để hệ thống tính tuyến.";
            return;
        }

        if (Form.WeightKg <= 0)
        {
            EstimatedShippingFeeAmount = 0;
            ResetFeeBreakdown();
            FeeEstimateMessage = "Nhập khối lượng hợp lệ để hệ thống tính phí.";
            return;
        }

        if (Form.LengthCm <= 0 || Form.WidthCm <= 0 || Form.HeightCm <= 0)
        {
            EstimatedShippingFeeAmount = 0;
            ResetFeeBreakdown();
            EstimatedVolumetricWeightKg = 0;
            EstimatedChargeableWeightKg = Form.WeightKg;
            FeeEstimateMessage = "Nhập đầy đủ kích thước kiện hàng để hệ thống tính phí.";
            return;
        }

        IsFeeEstimateLoading = true;

        try
        {
            var result = await ShippingFeeService.CalculateAsync(
                Form.RouteType,
                new Weight(Form.WeightKg),
                new ParcelDimensions(Form.LengthCm, Form.WidthCm, Form.HeightCm),
                new Money(Form.GoodsValueAmount, CurrentCurrency));

            if (result.IsFailure)
            {
                EstimatedShippingFeeAmount = 0;
                ResetFeeBreakdown();
                FeeEstimateMessage = UiDisplay.ToErrorMessage(result.Error);
                return;
            }

            EstimatedShippingFeeAmount = result.Value.TotalFee.Amount;
            EstimatedBaseFeeAmount = result.Value.BaseFee.Amount;
            EstimatedExtraWeightFeeAmount = result.Value.ExtraWeightFee.Amount;
            EstimatedInsuranceFeeAmount = result.Value.InsuranceFee.Amount;
            EstimatedReturnFeeAmount = result.Value.ReturnFee.Amount;
            EstimatedShippingFeeCurrency = result.Value.TotalFee.Currency;
            EstimatedVolumetricWeightKg = result.Value.VolumetricWeightKg;
            EstimatedChargeableWeightKg = result.Value.ChargeableWeightKg;
        }
        finally
        {
            IsFeeEstimateLoading = false;
        }
    }

